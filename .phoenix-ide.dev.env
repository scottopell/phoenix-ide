# Phoenix IDE -- DEV-ONLY env overrides. Loaded after .phoenix-ide.env in
# `./dev.py up/restart`, NOT loaded by `./dev.py prod deploy`. Tracked in
# git as the sane default for local dev; override per-machine by setting
# the same keys in your shell environment (which dev.py copies first) or
# by editing this file locally.

# Disable password auth for the dev instance (REQ-AUTH-001: empty value =
# no auth). Prod keeps its password from .phoenix-ide.env.
PHOENIX_PASSWORD=
