-- allium: 3
-- projects.allium
--
-- Phoenix Project Lifecycle: Behavioural Specification
--
-- Scope: Git-backed project lifecycle around bedrock conversations
-- Includes: Project detection, mode selection (Direct/Managed/Branch),
--           branch discovery, task approval, worktree lifecycle,
--           task file lifecycle, mark-as-merged flow, abandon flow,
--           write scoping, sub-agent worktree inheritance,
--           server restart worktree reconciliation
-- Excludes:
--   - Conversation state machine (see bedrock.allium)
--   - Platform capability detection (infrastructure)
--   - UI layout (confirmation dialogs, project switcher, badges)
--   - .gitignore management (handled by git_ops module)
--   - Diff snapshot capture (implementation detail of abandon)
--
-- Implementation notes (not normative):
--   Git operations consolidated in src/git_ops.rs (materialize_branch,
--   create_worktree, check_branch_conflict). API handlers split across
--   src/api/handlers.rs, src/api/git_handlers.rs, src/api/lifecycle_handlers.rs.
--   State machine uses CoreState/ParentState/SubAgentState wrapper pattern
--   (see bedrock.allium task 02668 for spec alignment).
--
-- Requirement traceability: REQ-PROJ-001 through REQ-PROJ-029
-- (2 descoped: REQ-PROJ-009, REQ-PROJ-015)

use "./bedrock.allium" as bedrock

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

-- A git repository on disk. This spec does not govern git internals,
-- only what operations the project lifecycle performs. The single
-- remote "origin" is implicit: every git operation in this spec either
-- targets origin or is a local operation; no rule here enumerates
-- multiple remotes.
external entity GitRepository {
    root_path: String
    current_branch: String
    -- Cached symbolic ref: refs/remotes/origin/HEAD → short name.
    -- Set by git clone, updated by git fetch. May be absent.
    remote_default_branch: String?
}

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value WorktreePath {
    -- Always `.phoenix/worktrees/{conversation_id}` relative to repo root.
    -- Unique by construction: derived from conversation ID.
    absolute_path: String
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum TaskFileStatus { in_progress | done | wont_do }

-- Worktree lifecycle is determined by conversation.mode (work vs branch).
-- No separate WorktreeKind enum needed -- the mode IS the kind.

-- A branch entry as presented to the user in the branch picker.
value BranchEntry {
    name: String
    local: Boolean                   -- exists as a local ref
    remote: Boolean                  -- exists as a remote tracking ref
    behind_remote: Integer?          -- commits local is behind origin (local compare, no network); non-negative
}

-- Cached output of `git ls-remote` for a repository.
value LsRemoteCache {
    repo_path: String
    refs: List<RemoteRef>
    fetched_at: Timestamp
    ttl_seconds: Integer = 300        -- 5 minutes
}

value RemoteRef {
    name: String                     -- short name (e.g. "main", "sopell/feature-x", "v2.1.0")
    kind: RefKind
    sha: String
}

enum RefKind { branch | tag }

------------------------------------------------------------
-- Entities
------------------------------------------------------------

-- A git-backed project with conversations and task files.
-- Non-git directories do not have a Project entity.
entity Project {
    repo: GitRepository

    -- ls-remote output cached for branch-picker typeahead.
    -- Refreshed on miss/expiry by SearchRemoteBranches.
    ls_remote_cache: LsRemoteCache?

    -- Most recent branch-picker response (local listing or search result).
    -- A BranchEntry list rendered to the UI.
    branch_picker_entries: List<BranchEntry>

    -- Relationships
    conversations: bedrock/Conversation with project = this
    task_files: TaskFile with project = this

    -- Projections
    active_task_files: task_files where status = in_progress
    work_conversations: conversations where mode in { work, branch }
}

-- A task file in the tasks/ directory, committed on the task branch.
entity TaskFile {
    project: Project
    task_id: String                -- NNNN format (date-based sequential)
    title: String
    priority: String               -- p0, p1, p2, p3
    slug: String
    status: TaskFileStatus
    created_at: Timestamp

    -- Filename: {task_id}-{priority}-{status}--{slug}.md
    filename: derive_filename(task_id, priority, status, slug)

    transitions status {
        in_progress -> done
        in_progress -> wont_do
        terminal: done, wont_do
    }

    -- Entity-level invariants
    invariant FilenameMatchesFrontmatter {
        filename = derive_filename(task_id, priority, status, slug)
    }
}

-- A git worktree for an isolated conversation.
-- Exists while the conversation is in Explore, Work, or Branch mode.
-- Lifecycle rules differ by conversation mode:
--   Work (Managed): Phoenix created the branch, task file present, branch deleted on terminal.
--   Branch: user's existing branch, no task file, branch kept on terminal.
entity Worktree {
    conversation: bedrock/Conversation
    project: Project
    path: WorktreePath
    branch_name: String            -- task-{NNNN}-{slug} (managed) or existing branch (branch mode)
    base_branch: String            -- recorded at creation time
    task_file: TaskFile?           -- present only for managed (work mode) worktrees

    -- REQ-PROJ-023: commits ahead/behind remote tracking ref.
    -- Updated by CommitsBehindPoll. Absent before the first poll fires
    -- (or when the conversation has no connected clients).
    commits_behind: Integer?
    commits_ahead: Integer?

    -- Derived
    is_clean: git_status_clean(path)
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    worktree_base_dir: String = ".phoenix/worktrees"
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- ===========================================================
-- 1. PROJECT DETECTION & MODE (REQ-PROJ-001, 002, 016, 018)
-- ===========================================================

-- REQ-PROJ-001: Git directory detected as project
rule GitDirectoryDetected {
    when: ConversationCreated(conversation, directory)

    requires: is_git_repository(directory)

    ensures: Project.created(
        repo: git_repo_at(directory)
    )

    @guidance
        -- The project is associated with the git repository root,
        -- not the provided directory (which may be a subdirectory).
}

-- REQ-PROJ-002/018: Default mode is Direct
rule DefaultModeIsDirect {
    when: ConversationCreated(conversation, directory)

    ensures: conversation.mode = direct

    @guidance
        -- Direct is zero-friction default for all conversations.
        -- Managed (Explore/Work) is opt-in via "Managed" selection.
}

-- REQ-PROJ-002: User selects Managed mode for git repo
rule ManagedModeSelected {
    when: UserSelectsManaged(conversation)

    requires: is_git_repository(conversation.working_dir)

    ensures: conversation.mode = explore
}

-- REQ-PROJ-024/029: User selects Branch mode for git repo
rule BranchModeSelected {
    when: UserSelectsBranch(conversation, branch_name)

    requires: is_git_repository(conversation.working_dir)
    requires: branch_name != ""

    -- REQ-PROJ-025: check for existing worktree/conversation on this branch
    requires: not exists active_worktree_on_branch(conversation.project, branch_name)
        or BranchConflictResolved(conversation, branch_name)

    -- Single-branch fetch (REQ-PROJ-022)
    ensures: BestEffortFetch(conversation.project.repo, branch_name)

    -- Create worktree on the existing branch (no new branch)
    ensures: Worktree.created(
        conversation: conversation,
        project: conversation.project,
        path: WorktreePath { absolute_path: worktree_path(conversation) },
        branch_name: branch_name,
        base_branch: branch_name,
        task_file: absent
    )
    ensures: conversation.mode = branch

    @guidance
        -- Unlike Managed mode, Branch mode skips Explore entirely.
        -- The worktree checks out the existing branch (not a new branch).
        -- `git worktree add <path> <branch>` (no -b flag).
        -- conversation.mode = branch (distinct from work).
        -- Branch mode carries its own fields on the Conversation entity:
        --   branch_mode_branch, branch_mode_worktree_path
        -- No task_id, no task file, no base_branch distinction.
        -- The agent's first message is delivered immediately.
}

-- REQ-PROJ-025: Branch conflict detection
rule BranchConflictDetected {
    when: UserSelectsBranch(conversation, branch_name)

    requires: exists active_worktree_on_branch(conversation.project, branch_name)

    -- Three conflict cases (case D -- terminal conversation -- is excluded):
    -- (A) Active conversation with worktree -> prompt redirect.
    --     A context-exhausted conversation counts as "active" here: its
    --     worktree is preserved pending Continue / Abandon (REQ-BED-031),
    --     so a user targeting the same branch should be offered the
    --     existing conversation rather than a fresh start.
    -- (B) Orphaned worktree (no conversation) -> prompt delete + fresh start.
    --     Rare in normal operation: ExploreWorktreeCleanupOnTerminal,
    --     MarkAsMerged, ConfirmAbandon, and
    --     ServerRestartWorktreeReconciliation collectively close every
    --     expected path to orphaning. This case only triggers for
    --     worktrees created by external git operations.
    -- (C) Stale conversation (no worktree) -> redirect to conversation
    -- All cases must be resolved before BranchModeSelected can proceed.

    ensures: BranchConflictPrompt(conversation, branch_name,
        existing_conversation: find_conversation_for_branch(branch_name),
        orphaned_worktree: find_orphaned_worktree(branch_name)
    )

    @guidance
        -- The prompt is shown in the /new page before conversation creation.
        -- "This branch is open in another conversation. Continue there?"
        -- For orphaned worktrees: "An orphaned worktree exists. Delete and
        --   start fresh?"
        -- For stale conversations: redirect to the existing conversation.
        -- Terminal conversations are excluded from conflict detection; the
        -- cleanup rules ensure their worktrees are gone by the time they
        -- reach terminal, so there is no filesystem contention either.
}

-- REQ-PROJ-028: Managed mode creates worktree on first message
rule ManagedWorktreeOnFirstMessage {
    when: UserSendsFirstMessage(conversation)

    requires: conversation.mode = explore
    requires: not exists Worktree{conversation: conversation}

    let base_branch = conversation.desired_base_branch
        or conversation.project.repo.current_branch
    let branch_name = derive_pending_branch_name(conversation.id)

    -- Single-branch fetch (REQ-PROJ-022)
    ensures: BestEffortFetch(conversation.project.repo, base_branch)

    ensures: Worktree.created(
        conversation: conversation,
        project: conversation.project,
        path: WorktreePath { absolute_path: worktree_path(conversation) },
        branch_name: branch_name,
        base_branch: base_branch,
        task_file: absent
    )
    -- conversation stays in Explore mode, agent reads from worktree

    @guidance
        -- The worktree is created from the selected base branch so the
        -- agent explores the right code (not the main checkout).
        -- A temporary branch name is used until task approval assigns
        -- the real task-{NNNN}-{slug} name.
        -- `git worktree add -b <temp-branch> <path> <base_branch>`
        -- The agent has read-only tools in this worktree.
}

-- REQ-PROJ-016/018: Non-git or Direct mode has no project features
-- (No propose_plan tool, no worktrees, no task files)
-- Enforced by tool registry configuration, not by rules.

-- ===========================================================
-- 2. BRANCH DISCOVERY (REQ-PROJ-020, 021, 022)
-- ===========================================================

-- REQ-PROJ-020: Local branch listing (no network)
-- Fires when the user opens the branch picker without a search query.
-- Emits a BranchEntry for each local branch, sorted by recency, with
-- `behind_remote` populated from local remote-tracking refs (no fetch).
rule ListLocalBranches {
    when: UserOpensBranchPicker(project)

    let repo = project.repo

    -- For each local branch on disk, a BranchEntry is produced with
    -- local = true, remote set iff the remote-tracking ref exists, and
    -- behind_remote computed as commits_between(local, remote-tracking)
    -- when the remote-tracking ref exists (otherwise absent).
    ensures: LocalBranchListingEmitted(project)

    @guidance
        -- `git for-each-ref --sort=-committerdate refs/heads/` returns
        -- branches ordered by last commit. All local operations, no network.
        --
        -- behind_remote is computed via:
        --   `git rev-list --count <local>..<remote-tracking>`
        -- Both refs are local; this is a graph walk, not a fetch.
        --
        -- remote_default_branch (if set on the repo) is included in the
        -- response so the UI can highlight it. Absent if symref is missing
        -- (never fetched, or remote has no HEAD). No fallback guessing.
        --
        -- Per-branch emission shape:
        --   BranchEntry {
        --       name: branch.short_name,
        --       local: true,
        --       remote: <exists remote-tracking ref>,
        --       behind_remote: commits_between(local, remote-tracking)
        --                      when remote-tracking ref exists, else absent
        --   }
}

-- REQ-PROJ-021: Remote branch search (network, on-demand).
-- Fires when the user types a non-empty query into the branch picker.
-- If the ls-remote cache is fresh, filter it; otherwise refresh and
-- filter. Response is a list of BranchEntry values matching the query
-- substring (case-insensitive). local is populated from the local
-- ref database; remote is always true; behind_remote is absent for
-- search results.
rule SearchRemoteBranches {
    when: UserSearchesBranches(project, query)

    requires: query != ""

    ensures: LsRemoteCacheRefreshedIfExpired(project)
    ensures: RemoteBranchSearchEmitted(project, query)

    @guidance
        -- `git ls-remote --heads --tags origin` lists all remote refs.
        -- Transfers only ref names and SHAs, no pack data.
        --
        -- Cache is keyed on repo_path. TTL is 5 minutes
        -- (LsRemoteCache.ttl_seconds = 300). Subsequent searches within
        -- TTL filter the cached list.
        --
        -- Per-result emission shape:
        --   BranchEntry {
        --       name: ref.name,
        --       local: <local ref exists>,
        --       remote: true,
        --       behind_remote: absent  -- not computed for search results
        --   }
        --
        -- Tags are included in results but only version-like tags
        -- (matching `v\d` or semver patterns) are useful in practice.
        -- Filtering is substring, not glob, for typeahead UX.
}

-- REQ-PROJ-022: Branch materialization (single-branch fetch at worktree creation)
rule MaterializeBranch {
    when: TaskApprovalStarted(conversation, base_branch_name)

    let repo = conversation.project.repo

    -- Always attempt a single-branch fetch, regardless of local/remote status.
    -- This is the moment where staleness is resolved.
    ensures: BestEffortFetch(repo, base_branch_name)

    ensures:
        if exists git_ref(repo, "refs/heads/" + base_branch_name):
            -- Local branch exists. If fetch succeeded, fast-forward to remote tip.
            FastForwardIfPossible(repo, base_branch_name)
        else if exists git_ref(repo, "refs/remotes/origin/" + base_branch_name):
            -- Remote-only. Create local tracking branch.
            CreateTrackingBranch(repo, base_branch_name, "origin/" + base_branch_name)
        else:
            -- Neither local nor remote. Fail.
            error("Branch '" + base_branch_name + "' not found locally or at origin")

    @guidance
        -- `git fetch origin <branch>` downloads objects for one branch only.
        -- Sub-second even on large repos.
        --
        -- Best-effort: if fetch fails (offline, auth, etc.), fall back to
        -- local ref. If no local ref exists and fetch failed, error out.
        --
        -- Fast-forward: `git fetch origin <branch>:<branch>` updates the
        -- local ref atomically if it's a fast-forward. If not (diverged),
        -- leave the local ref as-is and log a warning. The user chose this
        -- branch; forcing a reset would lose local commits.
        --
        -- Tracking branch: `git branch --track <name> origin/<name>`.
        -- Ensures merge-back and behind/ahead polling work on local refs.
}

-- ===========================================================
-- 3. TASK APPROVAL -- GIT OPERATIONS (REQ-PROJ-003, 004, 006, 012)
-- ===========================================================

-- REQ-PROJ-003/012: propose_plan tool intercepted by bedrock.
-- No git operations during propose/feedback loop. Plan exists only in memory.
-- Tool availability (Explore only, no sub-agents) enforced by bedrock.

-- REQ-PROJ-004/006/028: User approves task — permission upgrade + task file
-- Subscribes to bedrock's UserApprovesTask event (see bedrock.allium).
rule TaskApprovalExecuted {
    when: UserApprovesTask(conversation, decision)

    -- Bedrock handles the state transition (AwaitingTaskApproval -> LlmRequesting).
    -- This rule specifies the git side effects.
    -- REQ-PROJ-028: worktree already exists from ManagedWorktreeOnFirstMessage.
    -- Approval is a permission upgrade (Explore -> Work), not worktree creation.

    let worktree = Worktree{conversation: conversation}
    let project = conversation.project
    let proposal = conversation.proposal
    let task_id = next_task_id(project)
    let slug = derive_slug(proposal.title)
    let branch_name = "task-" + task_id + "-" + slug

    -- Rename the temporary branch to the final task branch name
    ensures: worktree.branch_name = branch_name

    -- Create and commit task file on the task branch (not main)
    ensures: TaskFile.created(
        project: project,
        task_id: task_id,
        title: proposal.title,
        priority: proposal.priority,
        slug: slug,
        status: in_progress,
        created_at: now
    )
    ensures: worktree.task_file = TaskFile{task_id: task_id}
    ensures: TaskFileCommittedOnBranch(worktree, task_id)

    -- Mode transition to Work
    ensures: conversation.branch_name = branch_name
    ensures: conversation.task_id = task_id

    @guidance
        -- All operations run under a global mutex to prevent concurrent
        -- approvals from getting the same task number.
        --
        -- Sequence:
        --   1. Assign task ID (date-based sequential via taskmd-core)
        --   2. Rename branch: `git branch -m <temp-name> <task-branch>`
        --   3. Write task file to tasks/ in the worktree
        --   4. Stage and commit on the task branch (not main)
        --   5. Transition Explore -> Work (permission upgrade)
        --
        -- The worktree and base_branch were set by
        -- ManagedWorktreeOnFirstMessage. No new worktree is created here.
        --
        -- Rollback:
        --   Task file write failure: remove file, reset
        --   Branch rename failure: keep temp name, log warning
}

-- REQ-PROJ-004 propose/feedback/reject loop: no git operations. The plan
-- exists only in memory until UserApprovesTask fires; until then the
-- agent can revise (UserProvidesFeedback) or the user can reject. This
-- spec emits no rule for those events because there is nothing to
-- specify — the bedrock state machine handles the transitions; this
-- file only describes git side-effects, and there are none.

-- ===========================================================
-- 4. TERMINAL ACTIONS (REQ-PROJ-026, REQ-PROJ-027)
-- ===========================================================
--
-- Push to remote is not modelled here. `git push` is a bash command the
-- agent may run from inside a worktree; Phoenix imposes no policy
-- beyond the bash-tool ban on `--force` (REQ-PROJ-019). Push has no
-- lifecycle side effects and no Phoenix-side observable state — the
-- terminal actions below (Mark-as-merged, Abandon) are the only
-- user-initiated lifecycle events on a Work/Branch conversation.

-- REQ-PROJ-026/027: User marks conversation as merged
rule MarkAsMerged {
    when: UserMarksAsMerged(conversation)

    let worktree = Worktree{conversation: conversation}

    -- Agent must not be running (no live tool execution, LLM call, etc.).
    requires: conversation.core_status = idle
    -- REQ-BED-031: permitted in normal idle (parent_status absent) and
    -- on a context-exhausted parent. Excludes awaiting_recovery /
    -- awaiting_task_approval / awaiting_user_response (those need
    -- user attention first) and terminal (already done).
    requires: conversation.parent_status = absent
           or conversation.parent_status = context_exhausted
    requires: conversation.mode in { work, branch }
    -- REQ-BED-031: same gate as ConfirmAbandon. A context-exhausted
    -- parent with an existing continuation cannot be marked-as-merged
    -- from the parent — the live conversation is the continuation, and
    -- any terminal decision on the work belongs there. See
    -- TerminalActionRequiresNoContinuation invariant.
    requires: conversation.continued_in_conv_id = absent

    ensures: not exists worktree
    ensures:
        if conversation.mode = work:
            -- Managed: Phoenix created this branch; delete it
            BranchDeleted(worktree.branch_name)
        -- Branch mode: keep the branch (it's the user's PR branch)

    ensures: bedrock/TaskResolved(
        conversation,
        system_message: "Marked as merged. Worktree deleted."
    )

    @guidance
        -- Sequence:
        --   1. `git worktree remove {path} --force`
        --      On failure: `rm -rf` + `git worktree prune`
        --   2. If managed: `git branch -D {branch}` (non-fatal)
        --      If branch: no branch deletion
        --   3. Send TaskResolved event
}

-- ===========================================================
-- 5. ABANDONMENT (REQ-PROJ-010, REQ-PROJ-026)
-- ===========================================================

-- REQ-PROJ-010/026, REQ-BED-031: User confirms abandonment.
-- Gated on `continued_in_conv_id = absent`: a context-exhausted parent
-- that has already been continued cannot be abandoned from the parent
-- (the continuation is the live conversation -- any abandon decision is
-- made there). See TerminalActionRequiresNoContinuation invariant.
rule ConfirmAbandon {
    when: UserConfirmsAbandon(conversation)

    let worktree = Worktree{conversation: conversation}

    -- Agent must not be running (no live tool execution, LLM call, etc.).
    requires: conversation.core_status = idle
    -- REQ-BED-031: permitted in normal idle (parent_status absent) and
    -- on a context-exhausted parent. Excludes awaiting_recovery /
    -- awaiting_task_approval / awaiting_user_response (those need
    -- user attention first) and terminal (already done).
    requires: conversation.parent_status = absent
           or conversation.parent_status = context_exhausted
    requires: conversation.mode in { work, branch }
    requires: conversation.continued_in_conv_id = absent

    ensures: not exists worktree
    ensures:
        if conversation.mode = work:
            -- Managed: Phoenix created this branch; delete it
            BranchDeleted(worktree.branch_name)
        -- Branch mode: keep the branch (it's the user's PR branch)

    ensures: bedrock/TaskResolved(
        conversation,
        system_message:
            if conversation.mode = work:
                "Task abandoned. Worktree and branch deleted."
            else:
                "Conversation abandoned. Worktree deleted, branch kept."
    )

    @guidance
        -- Abandon always succeeds from the user's perspective.
        -- The worktree is the critical resource; its deletion is the gate.
        --
        -- Sequence:
        --   1. Capture diff snapshot (non-fatal, before worktree deletion)
        --   2. `git worktree remove {path} --force`
        --      On failure: `rm -rf` + `git worktree prune`
        --   3. If managed: `git branch -D {branch}` (non-fatal)
        --      If branch: no branch deletion
        --   4. Send TaskResolved event
        --
        -- All uncommitted work in the worktree is permanently lost.
}

-- ===========================================================
-- 5a. WORKTREE CLEANUP ON CONVERSATION HARD-DELETE
--     (REQ-BED-032)
-- ===========================================================

-- REQ-BED-032 subscriber: when the user hard-deletes a conversation,
-- the bedrock cascade calls cascade_projects_on_delete which executes
-- this rule's effect. Fires only for conversations with a worktree
-- (Explore/Work/Branch modes); Direct-mode conversations have no
-- worktree and this rule is a no-op for them.
--
-- Distinct from ExploreWorktreeCleanupOnTerminal (5b): that rule fires
-- on terminal-state transition (e.g., context-exhausted with no
-- continuation, or task-resolution); this rule fires on user-initiated
-- hard-delete of the conversation record. Hard-delete can target a
-- non-terminal conversation, so this rule covers the case the prior
-- terminal-cleanup rules don't.
rule WorktreeRemovedByConversationDelete {
    when: ConversationHardDeleted(conversation)

    requires: exists Worktree{conversation: conversation}

    let worktree = Worktree{conversation: conversation}

    ensures: not exists worktree
    ensures:
        if conversation.mode = work:
            -- Managed (Work mode): Phoenix created the branch; delete it.
            BranchDeleted(worktree.branch_name)
        -- Branch mode: keep the branch (it's the user's PR branch).
        -- Explore mode: branch is the temp pending-task branch; delete.
        -- (TaskApprovalExecuted promotes Explore's temp branch to a
        -- task branch; pre-approval the branch is disposable.)

    @guidance
        -- Sequence (matches ConfirmAbandon's worktree-removal flow):
        --   1. `git worktree remove <path> --force`
        --      On failure: rm -rf <path> + git worktree prune
        --   2. If managed (Work mode): git branch -D <branch> (non-fatal)
        --   3. If Explore (pre-approval): git branch -D <branch> (non-fatal)
        --   4. If Branch mode: keep the branch entirely
        --
        -- Failure of any step is logged at WARN with structured fields
        -- (worktree_path, branch_name, conv_id) per REQ-BED-032's no-
        -- recovery policy. The orchestrator continues to the next
        -- cascade step.
        --
        -- Diff snapshot capture (the implementation detail of
        -- ConfirmAbandon) is NOT performed for hard-delete: the user
        -- chose to hard-delete the conversation, not abandon a task.
        -- Uncommitted work in the worktree is permanently lost.
}

-- ===========================================================
-- 5b. WORKTREE CLEANUP ON TERMINAL TRANSITION
--     (REQ-PROJ-028, REQ-PROJ-025, REQ-BED-021)
-- ===========================================================

-- REQ-PROJ-028: Managed Explore conversation reaches terminal without
-- entering Work mode. Clean up the worktree and temp branch.
-- Subscribes to bedrock's ConversationBecameTerminal lifecycle event
-- (see bedrock.allium).
rule ExploreWorktreeCleanupOnTerminal {
    when: ConversationBecameTerminal(conversation)

    requires: conversation.mode = explore
    requires: exists Worktree{conversation: conversation}
    -- REQ-BED-031 exemption: context-exhausted Explore conversations
    -- with a worktree are paused pending user action (continue or
    -- abandon), not normal-flow terminal cleanups. The worktree is
    -- preserved; cleanup fires only on actual terminal actions
    -- (ConfirmAbandon, MarkAsMerged) where continued_in_conv_id is
    -- absent. See WorktreeTransferredOnContinuation for the transfer
    -- path and TerminalActionRequiresNoContinuation for the gate.
    requires: conversation.parent_status != context_exhausted
    requires: conversation.continued_in_conv_id = absent

    let worktree = Worktree{conversation: conversation}

    ensures: not exists worktree
    ensures: BranchDeleted(worktree.branch_name)

    @guidance
        -- Fires when an Explore conversation with a worktree reaches
        -- terminal state (user abandoned without ever approving a task).
        -- The temp branch (task-pending-*) and worktree are cleaned up.
        -- Complements ServerRestartWorktreeReconciliation, which catches
        -- the crash case. This rule handles the normal-operation case.
        -- Skips context-exhausted conversations and conversations with
        -- a continuation — those paths preserve the worktree.
}

-- REQ-BED-030/031: Context-exhausted Work/Branch conversations are a
-- *paused* state, not a terminal cleanup. The worktree is preserved on
-- disk; the branch is preserved in git; the conversation record is
-- preserved for history navigation. The worktree stays until the user
-- takes an explicit action:
--   - Continue: worktree ownership transfers to the continuation
--     (WorktreeTransferredOnContinuation below).
--   - Abandon: normal abandon flow (ConfirmAbandon) runs; only permitted
--     while `continued_in_conv_id` is null (TerminalActionRequiresNoContinuation).
--   - Mark as merged on the continuation chain's tail: the chain's
--     normal terminal semantics apply (MarkAsMerged / ConfirmAbandon
--     there destroy the worktree; the parent's worktree_path becomes a
--     stale history reference).
--
-- The prior destroy-on-terminal rule is gone; no ConversationBecameTerminal
-- listener fires for Work/Branch + context_exhausted. Context-exhausted
-- stays a first-class paused state of the conversation entity.

-- REQ-BED-030: User initiates continuation from a context-exhausted
-- parent with a live Work or Branch worktree. A new conversation is
-- created that inherits the parent's environment; worktree ownership
-- transfers atomically. No `git worktree add` or `git worktree remove`
-- runs -- the filesystem state is unchanged.
rule WorktreeTransferredOnContinuation {
    when: UserStartsContinuationConversation(parent, new_conv)

    requires: parent.parent_status = context_exhausted
    -- Explore is included: REQ-PROJ-028 / ManagedWorktreeOnFirstMessage
    -- creates a worktree (on a temp branch) for every Explore conversation
    -- on first message, before any task approval. A context-exhausted
    -- Explore conversation therefore has a worktree to transfer.
    requires: parent.mode in { work, branch, explore }
    requires: exists Worktree{conversation: parent}
    -- Single-continuation policy: the parent may not already have one.
    requires: parent.continued_in_conv_id = absent

    let worktree = Worktree{conversation: parent}

    -- New conversation inherits mode, cwd, and worktree from parent.
    ensures: new_conv.mode = parent.mode
    ensures: new_conv.working_dir = parent.working_dir
    ensures: new_conv.worktree_path = parent.worktree_path
    ensures: new_conv.branch_name = parent.branch_name
    ensures: new_conv.base_branch = parent.base_branch

    -- Parent retains its worktree_path as a read-only history reference;
    -- ownership is derived from continued_in_conv_id (set => continuation
    -- owns; absent => this record owns). See
    -- WorktreeOwnershipFollowsContinuationPointer invariant.
    ensures: parent.continued_in_conv_id = new_conv.id

    -- Worktree ownership transfers: the Worktree entity's conversation
    -- pointer moves from parent to new_conv. No filesystem mutation.
    ensures: worktree.conversation = new_conv

    @guidance
        -- Cross-reference: bedrock/design.md "Context Continuation
        -- Worktree Transfer (REQ-BED-030, REQ-BED-031)" for the data
        -- model change (continued_in_conv_id column), the atomic
        -- DB transaction sketch, and the mode-inheritance table.
        --
        -- Inheritance table (this rule covers the Work, Branch, and
        -- Explore rows):
        --   Work    -> Work:    worktree transferred, branch_name + task_id inherited
        --   Branch  -> Branch:  worktree transferred, branch_name inherited
        --   Explore -> Explore: worktree transferred, temp branch_name inherited
        --   Direct  -> Direct:  no worktree to transfer (covered by
        --     DirectContinuationInheritsCwd below; filesystem
        --     unchanged, only cwd and mode are inherited).
        --
        -- Atomicity:
        --   BEGIN;
        --   INSERT INTO conversations (id, conv_mode, cwd, ..., task_id)
        --     VALUES (new_id, <parent's mode clone>, <parent's cwd>, ...);
        --   UPDATE conversations SET continued_in_conv_id = new_id
        --     WHERE id = parent_id;
        --   COMMIT;
        -- Either the continuation is created with full inheritance, or
        -- no state changes. A partial apply would leave the parent
        -- claiming ownership of a worktree while the continuation
        -- expected to inherit it (or strand a continuation with no
        -- parent linkage).
        --
        -- The continuation_summary field (set by bedrock when entering
        -- context_exhausted) is carried forward as the opening system
        -- message of the new conversation. That contract is owned by
        -- bedrock; this rule only models the worktree and mode
        -- inheritance.
}

-- REQ-BED-030: Work-mode continuation also inherits the parent's task_id
-- (and therefore its task file, since the task file lives on the
-- transferred branch inside the transferred worktree). Ensures a new
-- task ID isn't minted for the same underlying task.
rule WorkContinuationInheritsTaskId {
    when: UserStartsContinuationConversation(parent, new_conv)

    requires: parent.parent_status = context_exhausted
    requires: parent.mode = work
    requires: parent.continued_in_conv_id = absent

    ensures: new_conv.task_id = parent.task_id
}

-- REQ-BED-030: Direct parents have no worktree, so continuation
-- inherits only cwd and mode. No ownership transfer happens; the
-- filesystem is untouched; WorktreeTransferredOnContinuation does not
-- fire for Direct. Explore is covered by WorktreeTransferredOnContinuation
-- above because REQ-PROJ-028 ensures every Explore conversation acquires
-- a worktree on first message.
rule DirectContinuationInheritsCwd {
    when: UserStartsContinuationConversation(parent, new_conv)

    requires: parent.parent_status = context_exhausted
    requires: parent.mode = direct
    requires: parent.continued_in_conv_id = absent

    ensures: new_conv.mode = parent.mode
    ensures: new_conv.working_dir = parent.working_dir
    ensures: parent.continued_in_conv_id = new_conv.id

    @guidance
        -- Direct covers both git-repo and non-git working directories
        -- per REQ-PROJ-018 -- there is no separate Standalone mode.
        -- The continuation inherits only the cwd and (via bedrock) the
        -- continuation summary. No filesystem or registry changes.
        --
        -- Note: an Explore conversation with a worktree (created by
        -- ManagedWorktreeOnFirstMessage but never promoted to Work via
        -- task approval) is outside this rule's scope. That worktree's
        -- disposition is governed by ExploreWorktreeCleanupOnTerminal
        -- at terminal time; context-exhausted preservation across
        -- server restart is handled by the reconcile skip rule below.
}

-- ===========================================================
-- 6. COMMITS-BEHIND POLLING (REQ-PROJ-011, REQ-PROJ-023)
-- ===========================================================

-- REQ-PROJ-023: Remote-aware commits-behind polling
rule CommitsBehindPoll {
    when: PollerFires(conversation, interval: 60 seconds)

    -- Skip for Branch mode: base_branch == branch_name, comparison is always 0.
    requires: conversation.mode = work
    requires: conversation.has_connected_clients

    let worktree = Worktree{conversation: conversation}

    -- Single-branch fetch before comparison (best-effort)
    ensures: BestEffortFetch(worktree.project.repo, worktree.base_branch)

    ensures: worktree.commits_behind =
        commits_between(worktree.branch_name, worktree.base_branch)
    ensures: worktree.commits_ahead =
        commits_between(worktree.base_branch, worktree.branch_name)

    -- Emit SSE only when values change. SSE is conversation-scoped
    -- (frontend subscribers attach to a conversation) but the values
    -- belong to the worktree.
    ensures:
        if values_changed:
            SseEmit(conversation, worktree.commits_behind, worktree.commits_ahead)

    @guidance
        -- `git fetch origin <base_branch>` before rev-list comparison.
        -- Single-branch fetch: sub-second, even on large repos.
        -- Failure is non-fatal; comparison proceeds against local refs.
        --
        -- Poller exits when broadcast channel has no receivers
        -- (client disconnected).
}

-- ===========================================================
-- 7. WRITE SCOPING (REQ-PROJ-007)
-- ===========================================================

-- REQ-PROJ-007: Writes scoped to worktree
rule WriteBlockedOutsideWorktree {
    when: WriteAttempted(conversation, target_path)

    requires: conversation.mode in { work, branch }
    requires: not is_within(target_path, conversation.worktree_path)

    ensures: WriteRejected(conversation, target_path,
        reason: "Write target is outside the worktree")
}

-- ===========================================================
-- 8. SUB-AGENT WORKTREE INHERITANCE (REQ-PROJ-008)
-- ===========================================================

-- REQ-PROJ-008: Work sub-agent inherits parent worktree
rule WorkSubAgentInheritsWorktree {
    when: SubAgentSpawned(parent, sub_agent, mode)

    requires: parent.mode in { work, branch }
    requires: mode = work

    -- Sub-agent works in same worktree
    ensures: sub_agent.working_dir = parent.worktree_path

    @guidance
        -- One Work sub-agent per parent (enforced by bedrock invariant).
        -- Sub-agent has write access to parent's worktree.
}

-- REQ-PROJ-008: Explore sub-agent reads from worktree or main
rule ExploreSubAgentDirectory {
    when: SubAgentSpawned(parent, sub_agent, mode)

    requires: mode = explore

    ensures:
        if parent.mode in { work, branch }:
            sub_agent.working_dir = parent.worktree_path
        else:
            sub_agent.working_dir = parent.working_dir

    @guidance
        -- Explore sub-agents are read-only regardless of parent mode.
        -- Multiple Explore sub-agents allowed in parallel.
}

-- ===========================================================
-- 9. WORKTREE RECONCILIATION ON SERVER RESTART
-- ===========================================================

-- Worktree reconciliation on server restart.
-- Complements bedrock's ServerRestart rule (which resets conversation
-- status to idle) with project-level cleanup: detect orphaned worktrees
-- and mark affected conversations as Terminal.
--
-- REQ-PROJ-015 descoped the dedicated registry, but acknowledged that
-- startup reconciliation handles orphan detection via ConvMode::Work
-- queries. This rule models that existing behaviour.
--
-- Orphan detection: worktree is orphaned if worktree_path is empty,
-- base_branch is empty, or the path does not exist on disk.
--
-- Disposition: a Work/Branch/Explore-with-worktree conversation whose
-- on-disk worktree has vanished can no longer run tools, complete its
-- task, or be continued meaningfully. Silently demoting to Explore/Direct
-- and resetting cwd to the project root would mislead the user ("why is
-- this conversation suddenly talking about main?"). Instead, mark the
-- row as Terminal and leave conv_mode, worktree_path, and cwd untouched
-- so the user keeps the original metadata for context and can hard-delete
-- when ready. The state machine already gates further activity on
-- Terminal, so no extra guards are needed.
--
-- project_id on the conversation row is preserved independently, so
-- sidebar grouping is retained.
rule ServerRestartWorktreeReconciliationWork {
    when: ServerRestarted(conversation)

    requires: conversation.mode = work
    -- REQ-BED-031 / REQ-PROJ-015 extension: context-exhausted conversations
    -- and conversations that have already handed ownership off to a
    -- continuation are NOT orphans. Their worktree is intentionally
    -- preserved; skip them entirely. See @guidance.
    requires: conversation.parent_status != context_exhausted
    requires: conversation.continued_in_conv_id = absent
    requires: conversation.state != terminal
    requires: conversation.worktree_path = ""
        or conversation.base_branch = ""
        or not exists_on_disk(conversation.worktree_path)

    ensures: conversation.state = terminal
    ensures: GitWorktreePruned(conversation.project)

    @guidance
        -- Runs once per affected conversation at server startup, before
        -- any conversation becomes active.
        --
        -- Sequence per affected conversation:
        --   1. Query all Work/Branch-mode conversations from database
        --   2. Skip context_exhausted rows (REQ-BED-031): the worktree
        --      is preserved pending user action (Continue / Abandon);
        --      missing-on-disk shouldn't happen for these but if it does,
        --      don't compound the problem by marking terminal.
        --   3. Skip rows with continued_in_conv_id set (REQ-BED-030): the
        --      parent's worktree_path is a history reference; the
        --      continuation owns the worktree. The continuation itself
        --      is reconciled under its own row.
        --   4. Skip rows already in Terminal (idempotent on restart loop).
        --   5. For remaining rows: check worktree_path and base_branch
        --      non-empty (or not a __LEGACY_EMPTY__ sentinel from the
        --      NonEmptyString shim that was introduced in schema phase A1),
        --      and worktree directory exists on disk.
        --   6. If any check fails: update conversation state to Terminal.
        --      conv_mode, worktree_path, and cwd are NOT mutated — the
        --      user keeps original metadata for context. The state
        --      machine already gates further activity on Terminal.
        --   7. Derive project root from worktree path
        --      ({root}/.phoenix/worktrees/{id} → {root})
        --   8. Run `git worktree prune` in project root (once per unique
        --      root, deduplicated across conversations) for git hygiene.
        --   9. Log summary: "{terminated} terminated out of {total} Work"
        --
        -- The three orphan sources this recovers from:
        --   A. Legacy rows: pre-NonEmptyString data with empty or
        --      __LEGACY_EMPTY__ sentinel fields. Migration 002
        --      (src/db/migrations.rs) sweeps these at startup; this rule
        --      is belt-and-suspenders.
        --   B. Crash window: process dies between `git worktree remove`
        --      succeeding and the DB update landing. The on-disk check
        --      catches this.
        --   C. External intervention: user `rm -rf`s the worktree or runs
        --      `git worktree prune` outside Phoenix. Same on-disk check.
        --
        -- Error handling:
        --   - State update failure: logged, conversation skipped
        --   - git worktree prune failure: logged at debug (non-fatal)
        --   - No exceptions propagated; process continues for remaining
        --     conversations
}

rule ServerRestartWorktreeReconciliationBranch {
    when: ServerRestarted(conversation)

    requires: conversation.mode = branch
    -- REQ-BED-031 / REQ-PROJ-015 extension: skip context-exhausted and
    -- handed-off rows. See Work variant @guidance for rationale.
    requires: conversation.parent_status != context_exhausted
    requires: conversation.continued_in_conv_id = absent
    requires: conversation.state != terminal
    requires: conversation.worktree_path = ""
        or conversation.base_branch = ""
        or not exists_on_disk(conversation.worktree_path)

    ensures: conversation.state = terminal
    ensures: GitWorktreePruned(conversation.project)

    @guidance
        -- Same disposition as the Work variant: orphaned worktree →
        -- mark Terminal, preserve mode/cwd/worktree_path. The previous
        -- "demote Branch → Direct + reset cwd to project root" behaviour
        -- has been retired in favour of preserving original metadata
        -- and letting the user decide whether to hard-delete.
}

-- REQ-PROJ-028: Explore conversations with a worktree also need
-- reconciliation when the worktree is orphaned. Same disposition as
-- Work/Branch — mark the row Terminal and preserve all fields.
rule ServerRestartWorktreeReconciliationExplore {
    when: ServerRestarted(conversation)

    requires: conversation.mode = explore
    -- REQ-BED-031 / REQ-PROJ-015 extension: Explore with a worktree can
    -- also reach context_exhausted (if it stalled before task approval);
    -- its worktree is preserved pending user action.
    requires: conversation.parent_status != context_exhausted
    requires: conversation.continued_in_conv_id = absent
    requires: conversation.state != terminal
    requires: conversation.worktree_path != ""
    requires: conversation.worktree_path = ""
        or conversation.base_branch = ""
        or not exists_on_disk(conversation.worktree_path)

    ensures: conversation.state = terminal
    ensures: GitWorktreePruned(conversation.project)
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

-- REQ-PROJ-005: Worktree paths unique by construction
invariant WorktreePathDerivedFromConversation {
    for w in Worktrees:
        w.path.absolute_path = w.project.repo.root_path
            + "/" + config.worktree_base_dir + "/" + w.conversation.id
}

-- REQ-PROJ-005: No two worktrees share a path
invariant WorktreePathsUnique {
    for a in Worktrees:
        for b in Worktrees:
            a != b implies a.path != b.path
}

-- One worktree per Work conversation
invariant OneWorktreePerConversation {
    for a in Worktrees:
        for b in Worktrees:
            a != b implies a.conversation != b.conversation
}

-- REQ-PROJ-017: Base branch is immutable once recorded
-- (Enforced by construction: base_branch is resolved at approval time
-- from desired_base_branch or current HEAD, then stored in ConvMode::Work.
-- No rule updates it after approval.)

-- Task file exists after approval (managed worktrees only)
invariant TaskFileExistsForManagedWorktrees {
    for w in Worktrees where w.conversation.mode = work:
        w.conversation.mode = work implies exists w.task_file
}

-- REQ-PROJ-024: Branch mode worktrees never have task files
invariant BranchModeHasNoTaskFile {
    for w in Worktrees where w.conversation.mode = branch:
        w.task_file = absent
}

-- REQ-PROJ-025: No two active worktrees on the same branch
invariant OneBranchOneActiveWorktree {
    for a in Worktrees:
        for b in Worktrees:
            a != b implies a.branch_name != b.branch_name
}

-- Task file status consistency with conversation lifecycle
invariant TaskFileStatusMatchesLifecycle {
    for t in TaskFiles:
        t.status = in_progress implies
            t.project.work_conversations.any(c => c.task_id = t.task_id)
}

-- REQ-PROJ-020/022: No blanket fetches. Every `git fetch` call produced by
-- any rule in this spec must include a refspec targeting a single branch;
-- `git fetch --prune` (all refs) is prohibited. Every BestEffortFetch
-- emitted above carries a concrete branch name as its second argument --
-- this is an audit property of the @guidance, not a structural claim about
-- entities.

-- REQ-PROJ-020: behind_remote, when present, counts commits on the remote
-- tracking ref that are not yet on the local branch; it is never negative.
invariant BranchEntryBehindRemoteNonNegative {
    for e in BranchEntries:
        e.behind_remote != absent implies e.behind_remote >= 0
}

-- REQ-PROJ-021: The ls-remote cache TTL is a non-negative duration.
-- Freshness is decided by (now - fetched_at) vs ttl_seconds; a negative
-- TTL would leave the cache permanently expired.
invariant LsRemoteCacheTtlNonNegative {
    for c in LsRemoteCaches:
        c.ttl_seconds >= 0
}

-- REQ-BED-030: Single-continuation policy. A parent conversation has at
-- most one continuation. Once `continued_in_conv_id` is set, it points
-- at a valid conversation and is never overwritten. Structurally, the
-- field holds a single optional conversation id; the only rule that
-- writes it is WorktreeTransferredOnContinuation (and the worktree-less
-- sibling), and both require `continued_in_conv_id = absent` as a
-- precondition. Fork attempts therefore fail at the rule's guard.
invariant ContinuationPointerIsSingleValued {
    for c in Conversations:
        c.continued_in_conv_id != absent implies
            exists Conversation{id: c.continued_in_conv_id}
}

-- REQ-BED-030: Worktree ownership is derived from the continuation
-- pointer. The Worktree entity has exactly one `conversation` pointer;
-- when a parent has handed off, that pointer references the continuation,
-- not the parent. The parent's `worktree_path` field remains set for
-- history navigation but is no longer the authoritative owner.
-- This invariant pins the rule: for every Worktree, its conversation
-- has `continued_in_conv_id = absent` (the ownership row is the
-- continuation row, if the chain has any hand-offs).
invariant WorktreeOwnershipFollowsContinuationPointer {
    for w in Worktrees:
        w.conversation.continued_in_conv_id = absent
}

-- REQ-BED-031: A context-exhausted parent with a continuation cannot be
-- abandoned; the abandon UI targets the continuation in that case.
-- Structurally enforced by the `continued_in_conv_id = absent` clauses
-- on ConfirmAbandon and MarkAsMerged. This invariant names the contract
-- for auditability: any user-triggered terminal action on a conversation
-- leaves that conversation with `continued_in_conv_id = absent` at the
-- time of the transition. A context-exhausted parent that has been
-- continued is operated on via the continuation, not the parent — both
-- abandon and mark-as-merged follow the same rule.
invariant TerminalActionRequiresNoContinuation {
    for c in Conversations:
        UserConfirmsAbandon(c) implies c.continued_in_conv_id = absent
    for c in Conversations:
        UserMarksAsMerged(c) implies c.continued_in_conv_id = absent
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface ProjectManagement {
    facing: bedrock/User

    context conversation: bedrock/Conversation
        where mode in { work, branch } and core_status = idle

    let worktree = Worktree{conversation: conversation}

    exposes:
        worktree.branch_name
        worktree.base_branch
        conversation.mode
        worktree.is_clean
        worktree.task_file.status when conversation.mode = work

    provides:
        UserMarksAsMerged(conversation)
        UserConfirmsAbandon(conversation)

    @guarantee NonFatalBookkeeping
        -- Task file status updates are best-effort. If they fail,
        -- the completion/abandonment still proceeds. Failures are logged.
}

surface BranchPicker {
    facing: bedrock/User

    context project: Project

    exposes:
        ListLocalBranches(project)         -- instant, no network
        SearchRemoteBranches(project, query) -- on-demand, cached ls-remote
        project.repo.remote_default_branch

    provides:
        UserOpensBranchPicker(project)
        UserSearchesBranches(project, query)

    @guarantee ListingIsInstant
        -- The no-query branch listing path never touches the network.
        -- It returns local branches sorted by recency with staleness
        -- signals based on cached remote-tracking refs.

    @guarantee SearchIsCached
        -- `git ls-remote` results are cached for at least 5 minutes.
        -- Rapid successive keystrokes filter the cache, not the network.

    @guarantee MaterializationIsTargeted
        -- When a branch is selected and the task is approved, only that
        -- branch is fetched. No blanket `git fetch` or `git fetch --prune`.
}

-- No open questions. All requirements are either modeled or explicitly
-- excluded by scope (UI layout, platform detection, descoped registry).
