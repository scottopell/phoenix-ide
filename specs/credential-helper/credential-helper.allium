-- Credential Helper Specification
--
-- Interactive LLM API key helper support.
-- When LLM_API_KEY_HELPER is configured, this spec governs the lifecycle
-- of the helper subprocess, credential caching, and UI surface.
--
-- Does NOT import bedrock; the credential helper is a global concern
-- orthogonal to any individual conversation.

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    -- Shell command that emits the credential on its last stdout line.
    -- When null, this spec's rules do not apply (static/env credential path).
    helper_command: String?
    helper_configured: helper_command != null

    -- How long a cached credential remains valid (default 2 hours).
    ttl: Duration = 7_200_000.ms
}

------------------------------------------------------------
-- Entities
------------------------------------------------------------

-- The credential helper. Exactly one instance exists when helper_configured.
-- Represents the subprocess lifecycle and cached credential state.
entity CredentialHelper {
    status: idle | running | valid | failed

    -- present only when running
    lines_emitted: Vec<String> when status = running

    -- present only when valid
    credential: String          when status = valid
    expires_at: Timestamp       when status = valid

    -- present only when failed
    exit_code: Integer?         when status = failed
    error_output: String        when status = failed

    derived is_expired: status = valid and now >= expires_at
}

------------------------------------------------------------
-- Actors
------------------------------------------------------------

-- The Phoenix server process. Spawns and reaps the helper subprocess.
actor Server

-- A browser session that has opened the auth panel.
actor AuthPanelClient {
    identified_by: SSE connection to POST /api/credential-helper/run
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

-- Exposes credential status for the models API response.
-- Consumed by the UI to render the AUTH indicator.
surface CredentialStatusSurface {
    facing server: Server

    exposes:
        helper.status
        helper.is_expired
        helper.expires_at when helper.status = valid

    derived credential_status_api:
        when not config.helper_configured  → not_configured
        when helper.status = valid
             and not helper.is_expired     → valid
        when helper.status = idle
             or helper.is_expired         → required
        when helper.status = running      → running
        when helper.status = failed       → failed
}

-- Auth panel surface. Client subscribes to a run and receives output.
surface AuthPanelSurface {
    facing client: AuthPanelClient

    context helper: CredentialHelper where config.helper_configured

    exposes:
        -- Instruction lines emitted so far (replay on connect)
        helper.lines_emitted when helper.status = running
        -- Terminal states
        helper.status when helper.status in { valid, failed }
        helper.exit_code when helper.status = failed
        helper.error_output when helper.status = failed

    -- Note: helper.credential is NOT exposed — token is server-only.

    provides:
        UserTriggersAuth
            when helper.status in { idle, failed }
            or   helper.is_expired
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- User (or server on startup check) triggers auth.
-- Spawns the helper subprocess. Transitions idle/failed → running.
rule HelperStarted {
    when: UserTriggersAuth

    requires: config.helper_configured
    requires: helper.status in { idle, failed } or helper.is_expired

    ensures: helper.status = running
    ensures: helper.lines_emitted = []

    @guidance
        -- POST /api/credential-helper/run handler:
        -- 1. Lock HelperState.
        -- 2. If already running: skip spawn, proceed to HelperOutputBroadcast.
        -- 3. Transition to Running { lines_so_far: [], subscribers: [this_tx] }.
        -- 4. Unlock.
        -- 5. Spawn helper task (see HelperSucceeded / HelperFailed rules).
}

-- A line arrives on the helper's stdout.
-- Appended to replay buffer and broadcast to all subscribers.
-- The last non-empty line will become the credential on exit.
rule OutputLineForwarded {
    when: helper subprocess emits a stdout line

    requires: helper.status = running

    ensures: line appended to helper.lines_emitted
    ensures: line broadcast to all AuthPanelClients subscribed to this run

    @guidance
        -- Read stdout with tokio::io::BufReader::lines().
        -- Each line: push to lines_so_far, fan-out via mpsc channels.
        -- New subscribers (joining mid-run) receive replay of lines_so_far
        -- before switching to live broadcast.
        -- The credential line (last non-empty) is identified only at exit;
        -- it is broadcast as an ordinary instruction line and then the
        -- HelperSucceeded rule supersedes it from the server side.
        -- The token is never re-broadcast as a "this is your token" SSE event.
}

-- Helper exits with status 0.
-- Last non-empty stdout line is the credential; cached for TTL.
rule HelperSucceeded {
    when: helper subprocess exits with status 0

    requires: helper.status = running
    requires: exists line in helper.lines_emitted where line.trim() != ""

    let credential = last non-empty line in helper.lines_emitted

    ensures: helper.status = valid
    ensures: helper.credential = credential
    ensures: helper.expires_at = now + config.ttl
    ensures: complete event broadcast to all AuthPanelClients

    @guidance
        -- After BufReader EOF: collect last non-empty line as credential.
        -- Transition HelperInner to Valid { credential, expires_at }.
        -- Broadcast { type: "complete" } SSE event (no token in payload).
        -- Clear subscriber list.
}

-- Helper exits non-zero, or exits 0 with no non-empty stdout.
-- Credential is NOT cached. Error surfaced to UI.
rule HelperFailed {
    when: helper subprocess exits non-zero
       or (helper subprocess exits 0 and all lines in helper.lines_emitted are empty)

    requires: helper.status = running

    ensures: helper.status = failed
    ensures: helper.exit_code = subprocess exit code (null if signalled)
    ensures: helper.error_output = subprocess stderr (trimmed)
    ensures: error event broadcast to all AuthPanelClients

    @guidance
        -- Capture stderr alongside stdout (separate piped readers or interleaved).
        -- Broadcast { type: "error", exit_code: N, stderr: "..." } SSE event.
        -- Clear subscriber list.
        -- Do NOT cache any partial stdout content.
}

-- TTL elapses on a valid credential.
-- Status transitions to idle (effectively "required") on next read.
rule CredentialExpired {
    when: now >= helper.expires_at

    requires: helper.status = valid

    ensures: helper.status = idle

    @guidance
        -- Not a scheduled event -- detected lazily on CredentialStatusSurface
        -- read (is_expired derived value) and on CommandCredential::get().
        -- No background timer needed; check TTL on every status read.
}

-- LLM provider returns 401 or 403.
-- Cached credential immediately invalidated regardless of TTL.
rule CredentialInvalidatedOn401 {
    when: LLM provider returns HTTP 401 or 403

    requires: helper.status = valid

    ensures: helper.status = idle

    @guidance
        -- HelperState::invalidate() is called by LlmAuth on 401.
        -- Transitions Valid → Idle. Next /api/models poll returns "required".
        -- User must re-authenticate.
}

-- Second client connects while helper is already running.
-- Joins the existing run; no new subprocess spawned.
rule ConcurrentClientJoined {
    when: UserTriggersAuth

    requires: config.helper_configured
    requires: helper.status = running

    ensures: client receives replay of helper.lines_emitted
    ensures: client subscribed to live broadcast for remainder of run
    ensures: no new subprocess spawned

    @guidance
        -- POST /api/credential-helper/run handler finds status = Running.
        -- Adds new subscriber channel to the subscriber list.
        -- Replays lines_so_far to the new channel before live events.
        -- Returns the SSE stream for the new subscriber.
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

-- At most one helper subprocess running at any time.
invariant SingleConcurrentHelper {
    CredentialHelpers.filter(h => h.status = running).count <= 1
}

-- When valid, credential is always the last non-empty stdout line
-- from the most recent successful run.
invariant CredentialIsLastLine {
    for h in CredentialHelpers where h.status = valid:
        h.credential = last non-empty element of most_recent_run_stdout(h)
}

-- A failed run never leaves a credential cached.
invariant NoCredentialOnFailure {
    for h in CredentialHelpers where h.status = failed:
        not exists h.credential
}

-- The credential is never transmitted to browser clients via SSE.
-- (Implementation constraint; verified by audit, not runtime state.)
@invariant TokenNotInSSEPayload
    -- The { type: "complete" } event carries no credential field.
    -- OutputLineForwarded broadcasts all lines including the token line,
    -- but the token line is indistinguishable from instruction lines at
    -- broadcast time — the server identifies it only after exit. This is
    -- acceptable: the token line from most OIDC flows is a raw JWT which
    -- the browser cannot use without the server intermediating the request.
    -- If stricter isolation is needed, buffer the last line server-side and
    -- only broadcast N-1 lines. Track as a future hardening task if required.

