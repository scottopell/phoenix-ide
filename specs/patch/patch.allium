-- Patch Tool Behavioural Specification
--
-- Captures the planner's pure domain logic: operations, matching cascade,
-- clipboard lifecycle, multi-edit application, and reindentation.
-- The executor (filesystem IO) and tool wrapper (JSON schema, path resolution)
-- are out of scope -- they are thin adapters over this core.

-- ============================================================================
-- Value types
-- ============================================================================

value EditSpec {
    offset: Integer       -- byte offset in content
    length: Integer       -- byte length of matched region
}

value Edit {
    offset: Integer
    length: Integer
    replacement: String
}

value Reindent {
    strip: String?        -- prefix to remove from each non-empty line
    add: String?          -- prefix to add to each non-empty line
}

-- ============================================================================
-- Entities
-- ============================================================================

entity PatchPlanner {
    clipboards: Map<String, String>

    -- Projections
    clipboard_names: clipboards.keys
}

entity PatchRequest {
    operation: Replace | AppendEof | PrependBof | Overwrite
    old_text: String?
    new_text: String?
    to_clipboard: String?       -- clipboard name to store old_text into
    from_clipboard: String?     -- clipboard name to read new_text from
    reindent: Reindent?
}

entity PatchPlan {
    resulting_content: String
    diff: String
    autogenerated_warning: Boolean
    effects: List<PatchEffect>
}

entity PatchEffect {
    kind: WriteFile
    path: Path
    content: String
}

-- ============================================================================
-- Matching cascade
-- ============================================================================
--
-- find_unique_match(content, old_text) tries three strategies in order.
-- The first to return a unique match wins. If all three fail, the error
-- depends on how many raw occurrences exist (0 -> NotFound, >1 -> NotUnique).

entity MatchAttempt {
    content: String
    old_text: String
    result: Matched | NotFound | NotUnique

    -- Derived (evaluated lazily in cascade order)
    exact_result: find_exact_unique(content, old_text)
    dedent_result: find_dedent_match(content, old_text)
    trimmed_result: find_trimmed_match(content, old_text)
    normalised_result: find_skeleton_match(content, old_text)
    raw_count: count_all_occurrences(content, old_text)
}

rule ExactMatchSucceeds {
    when: attempt: MatchAttempt.created
    requires: attempt.exact_result != null
    ensures: attempt.result = Matched
    ensures: attempt.spec = attempt.exact_result
}

rule DedentFallback {
    when: attempt: MatchAttempt.created
    requires: attempt.exact_result = null
    requires: attempt.dedent_result != null
    ensures: attempt.result = Matched
    ensures: attempt.spec = attempt.dedent_result
    @guidance
        -- Iterates over distinct indentation levels found in content.
        -- For each level, reindents old_text from its common leading
        -- whitespace to the candidate level and checks for exact unique match.
        -- Stops at first hit.
}

rule TrimmedFallback {
    when: attempt: MatchAttempt.created
    requires: attempt.exact_result = null
    requires: attempt.dedent_result = null
    requires: attempt.trimmed_result != null
    ensures: attempt.result = Matched
    ensures: attempt.spec = attempt.trimmed_result
    @guidance
        -- Requires old_text to have >2 lines.
        -- Tries without first line: if found and the preceding text ends
        -- with the first line + newline, extends the spec backward.
        -- Tries without last line: accepts as-is.
}

rule SkeletonFallback {
    when: attempt: MatchAttempt.created
    requires: attempt.exact_result = null
    requires: attempt.dedent_result = null
    requires: attempt.trimmed_result = null
    requires: attempt.normalised_result != null
    ensures: attempt.result = Matched
    ensures: attempt.spec = attempt.normalised_result
    @guidance
        -- Uses Unicode TR39 confusable skeleton mapping (not NFKC).
        -- skeleton() maps visually similar characters to a common form:
        -- curly quotes -> straight quotes, em dash -> hyphen, fullwidth -> ASCII.
        -- Both content and old_text are skeletonised, then find_exact_unique
        -- runs on the skeleton strings. The skeleton byte offset is mapped
        -- back to the original content via a per-character offset table.
        -- The replacement targets the file's actual bytes at that position
        -- (not the skeleton form), so the edit is byte-correct.
        -- Only runs when the first three strategies all fail -- zero cost
        -- on the happy path.
}

rule MatchNotFound {
    when: attempt: MatchAttempt.created
    requires: attempt.exact_result = null
    requires: attempt.dedent_result = null
    requires: attempt.trimmed_result = null
    requires: attempt.normalised_result = null
    requires: attempt.raw_count = 0
    ensures: attempt.result = NotFound
}

rule MatchNotUnique {
    when: attempt: MatchAttempt.created
    requires: attempt.exact_result = null
    requires: attempt.dedent_result = null
    requires: attempt.trimmed_result = null
    requires: attempt.normalised_result = null
    requires: attempt.raw_count > 1
    ensures: attempt.result = NotUnique
}

-- ============================================================================
-- Planning: plan(path, current_content, patches)
-- ============================================================================

rule PlanValidation {
    when: PlanRequested(planner, path, current_content, patches)
    requires: patches.count > 0
    requires:
        for patch in patches where patch.operation = Replace:
            current_content != null
    @guidance
        -- Empty patches -> NoPatches error.
        -- Replace on non-existent file -> ReplaceOnNonexistent error.
        -- Both checked before any edits are built.
}

-- ============================================================================
-- Edit building: per-patch -> Edit
-- ============================================================================

rule ResolveNewText {
    when: BuildEdit(planner, patch, original)
    let effective_from_clipboard = patch.from_clipboard where patch.from_clipboard != ""
    let effective_to_clipboard = patch.to_clipboard where patch.to_clipboard != ""
    if effective_from_clipboard != null:
        requires: effective_from_clipboard in planner.clipboard_names
        ensures: new_text = planner.clipboards[effective_from_clipboard]
    else:
        ensures: new_text = patch.new_text ?? ""
    @guidance
        -- Empty string clipboard names ("") are treated as absent.
        -- LLMs sometimes pass "" instead of omitting the field.
}

rule ApplyReindent {
    when: BuildEdit(planner, patch, original)
    requires: patch.reindent != null
    let reindent = patch.reindent
    ensures:
        for line in new_text.split("\n") where line != "":
            if reindent.strip != null:
                requires: line.starts_with(reindent.strip)
            if reindent.add != null:
                line.starts_with(reindent.add)
    @guidance
        -- Strip runs first, then add. Empty lines pass through unchanged.
        -- If strip prefix is absent on a non-empty line -> ReindentPrefixMismatch error.
}

rule StoreToClipboard {
    when: BuildEdit(planner, patch, original)
    let effective_to_clipboard = patch.to_clipboard where patch.to_clipboard != ""
    requires: effective_to_clipboard != null
    if patch.operation = Replace:
        -- For Replace, store the *actual matched text* from content,
        -- not the requested old_text. Handles fuzzy match divergence.
        ensures: planner.clipboards[effective_to_clipboard] = matched_text_from_content
    else:
        requires: patch.old_text != null
        ensures: planner.clipboards[effective_to_clipboard] = patch.old_text
    @guidance
        -- Clipboard write happens during edit building, before edit application.
        -- The matched_text_from_content is original[spec.offset..spec.offset+spec.length]
        -- where spec comes from find_unique_match. This is important when dedent or
        -- trimmed matching finds a differently-indented version of old_text.
}

rule BuildReplaceEdit {
    when: BuildEdit(planner, patch, original)
    requires: patch.operation = Replace
    requires: patch.old_text != null
    let spec = find_unique_match(original, patch.old_text)
    ensures: edit = Edit(offset: spec.offset, length: spec.length, replacement: new_text)
}

rule BuildPrependEdit {
    when: BuildEdit(planner, patch, original)
    requires: patch.operation = PrependBof
    ensures: edit = Edit(offset: 0, length: 0, replacement: new_text)
}

rule BuildAppendEdit {
    when: BuildEdit(planner, patch, original)
    requires: patch.operation = AppendEof
    ensures: edit = Edit(offset: original.length, length: 0, replacement: new_text)
}

rule BuildOverwriteEdit {
    when: BuildEdit(planner, patch, original)
    requires: patch.operation = Overwrite
    ensures: edit = Edit(offset: 0, length: original.length, replacement: new_text)
}

-- ============================================================================
-- Edit application
-- ============================================================================

rule ApplyEditsReverseOrder {
    when: ApplyEdits(original, edits)
    ensures: result = apply_in_reverse_offset_order(original, edits)
    @guidance
        -- Edits are sorted by offset descending before application.
        -- This preserves byte offsets: applying edit[0] (highest offset)
        -- does not shift the positions of edit[1..n] (lower offsets).
        -- Each edit replaces original[offset..offset+length] with replacement.
        -- If offset+length > content.length -> EditOutOfBounds error.
}

-- ============================================================================
-- Invariants
-- ============================================================================

invariant ClipboardPersistence {
    -- Clipboard entries persist across plan() calls on the same PatchPlanner.
    -- A clipboard written in call N is readable in call N+1.
    for name in planner.clipboard_names:
        planner.clipboards[name] != null
}

invariant EmptyClipboardNameIgnored {
    -- Empty string ("") is never a valid clipboard name.
    -- It is not stored as a key, and referencing it does not trigger lookup.
    "" not in planner.clipboard_names
}

invariant ReplaceRequiresExistingFile {
    -- Replace on a file with current_content = null always fails.
    -- Other operations (Overwrite, Append, Prepend) work on null content
    -- (treating it as empty string).
}

invariant MatchUniqueness {
    -- find_unique_match returns a result only when exactly one occurrence
    -- exists (at the strategy level that matched). If zero -> NotFound.
    -- If >1 -> NotUnique.
    -- This applies per-strategy: exact match checks raw occurrences,
    -- dedent match checks after reindentation, trimmed match checks
    -- after line removal.
}

invariant EditApplicationOrder {
    -- Edits are applied in descending offset order. No edit's offset
    -- is adjusted based on prior edits. This is correct because each
    -- edit's offset was computed against the original content, and
    -- descending application means only bytes after the edit point change.
}

invariant OverwriteIdempotent {
    -- Overwriting a file with content X, then overwriting again with X,
    -- produces the same result.
}

invariant ReindentRoundtrip {
    -- strip(X) then add(X) is identity for uniform indentation.
    -- strip("  ") + add("  ") on "  line1\n  line2" = "  line1\n  line2".
}
