-- allium: 3
-- bedrock.allium
--
-- Phoenix Conversation Engine: Behavioural Specification
--
-- Scope: Core conversation lifecycle state machine
-- Includes: Conversation status transitions, mode system, tool execution,
--           cancellation, error recovery, sub-agent lifecycle, task approval,
--           user questions, context continuation, terminal states,
--           lifecycle event announcements for downstream spec consumption
-- Excludes:
--   - Git operations (see projects spec)
--   - Individual tool implementations (bash, patch, etc.)
--   - LLM provider specifics (Anthropic, OpenAI wire formats)
--   - Database persistence mechanics (SQLite, serde)
--   - SSE streaming / HTTP API design
--   - UI rendering / display state mapping
--   - Token streaming mechanics
--   - System prompt construction
--
-- Architecture: CoreState wrapper pattern.
--   Parent and sub-agent conversations share a core state space but have
--   structurally disjoint terminal/recovery states. The sum type (variants)
--   makes invalid states unrepresentable: parents cannot reach Completed/Failed,
--   sub-agents cannot reach AwaitingRecovery/TaskApproval/Terminal.
--
--   Events are similarly split: CoreEvent (shared), ParentOnlyEvent,
--   SubAgentOnlyEvent. The transition function dispatches by conversation kind.
--
--   ConvState (the union of all states) remains as the serialization format.
--
-- Requirement traceability: REQ-BED-001 through REQ-BED-030
-- (3 deprecated: REQ-BED-014, REQ-BED-015, REQ-BED-016)

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

external entity LlmProvider {
    context_window: Integer
}

external entity ToolImplementation {
    name: String
}

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value ToolCall {
    tool_use_id: String
    name: String
    input: String
}

value ToolResult {
    tool_use_id: String
    outcome: ToolOutcome
}

value SubAgentResult {
    agent_id: String
    outcome: SubAgentOutcome
}

value UsageData {
    input_tokens: Integer
    output_tokens: Integer
}

value UserQuestion {
    question: String
}

value TaskProposal {
    title: String
    priority: String
    plan: String
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

enum ErrorClass { retryable | non_retryable }
enum ToolOutcome { success | error | cancelled }
enum SubAgentOutcome { success | failure | timed_out }
enum RecoveryKind { credential }
enum TaskApprovalDecision { approved | rejected | feedback_provided }
enum ModeKind { direct | managed | branch }

------------------------------------------------------------
-- Entities
------------------------------------------------------------

-- Conversation uses a sum type to structurally separate parent and sub-agent
-- conversations. The kind discriminator determines which states are reachable.
entity Conversation {
    kind: Parent | SubAgent

    -- Seed metadata (REQ-SEED-003, REQ-SEED-004)
    seed_parent: Conversation?
    seed_label:  String?

    -- Core status (shared by both variants)
    core_status: idle | llm_requesting | executing_tools
                | cancelling_tool | awaiting_sub_agents | cancelling_sub_agents
                | error | awaiting_continuation

    -- Mode (orthogonal to status)
    mode: explore | direct | work | branch
    mode_kind: ModeKind
    desired_base_branch: String?

    -- Context tracking (REQ-BED-012)
    context_usage_ratio: Decimal
    model_context_window: Integer

    -- Core status transitions (shared)
    transitions core_status {
        idle -> llm_requesting
        error -> llm_requesting
        llm_requesting -> idle
        llm_requesting -> executing_tools
        llm_requesting -> error
        executing_tools -> llm_requesting
        executing_tools -> awaiting_sub_agents
        executing_tools -> cancelling_tool
        cancelling_tool -> idle
        cancelling_tool -> cancelling_sub_agents
        awaiting_sub_agents -> llm_requesting
        awaiting_sub_agents -> cancelling_sub_agents
        cancelling_sub_agents -> idle
        idle -> awaiting_continuation
    }

    -- Mode transitions (REQ-BED-027)
    transitions mode {
        explore -> work
        direct -> branch
        terminal: direct, work, branch
    }

    -- Core state-dependent fields
    retry_attempt: Integer when core_status = llm_requesting | awaiting_continuation
    tool_queue: List<ToolCall> when core_status = executing_tools
    tool_results: List<ToolResult> when core_status = executing_tools | cancelling_tool
    accumulated_sub_agents: Set<Conversation> when core_status = executing_tools
    skipped_tools: List<ToolCall> when core_status = cancelling_tool
    sub_agents_pending: Set<Conversation>
        when core_status = awaiting_sub_agents | cancelling_sub_agents
    sub_agents_completed: List<SubAgentResult>
        when core_status = awaiting_sub_agents | cancelling_sub_agents
    rejected_tool_calls: List<ToolCall> when core_status = awaiting_continuation
    error_message: String when core_status = error
    error_class: ErrorClass when core_status = error

    -- Worktree fields (shared across modes with worktrees)
    branch_name: String when mode in { explore, work, branch }
    worktree_path: String when mode in { explore, work, branch }
    base_branch: String when mode in { explore, work, branch }
    task_id: String when mode = work

    -- Relationships
    sub_agents: Conversation with parent = this
    work_sub_agents: sub_agents where mode in { work, branch }

    -- Derived
    is_busy: core_status in { llm_requesting, executing_tools,
                              awaiting_sub_agents, cancelling_tool,
                              cancelling_sub_agents }
    context_warning: context_usage_ratio >= config.context_warning_threshold
    context_at_threshold: context_usage_ratio >= config.context_continuation_threshold

    -- Entity-level invariants
    invariant OneWorkSubAgent {
        work_sub_agents.count <= 1
    }
}

-- Parent conversations: user-facing. Can propose tasks, recover from auth
-- errors, reach terminal via task resolution or context exhaustion.
-- CANNOT reach Completed or Failed (sub-agent-only).
variant Parent : Conversation {
    parent_status: awaiting_recovery | awaiting_task_approval
                  | awaiting_user_response | context_exhausted | terminal

    proposal: TaskProposal when parent_status = awaiting_task_approval
    pending_questions: List<UserQuestion> when parent_status = awaiting_user_response
    recovery_kind: RecoveryKind when parent_status = awaiting_recovery
    recovery_message: String when parent_status = awaiting_recovery
    continuation_summary: String when parent_status = context_exhausted

    is_terminal: parent_status in { context_exhausted, terminal }

    -- Parent-only status transitions.
    -- Recovery/approval/question states exit by resetting to a core_status
    -- (idle, llm_requesting, error). These are cross-field transitions:
    -- parent_status clears while core_status is set.
    --
    -- Transition graph (not expressible as a v3 `transitions` block because
    -- the Allium v3 grammar does not currently support transitions or
    -- invariants inside `variant` bodies — see the triage note below):
    --
    --   awaiting_task_approval -> idle            (task approval exits)
    --   awaiting_user_response -> idle            (user question exits)
    --   awaiting_recovery      -> idle            (recovery exits)
    --   awaiting_continuation  -> context_exhausted (continuation -> terminal)
    --   terminal states: context_exhausted, terminal
    --
    -- The rules below (parent-only section) realise each transition.
}

-- Sub-agent conversations: spawned by a parent, report results back.
-- CANNOT reach AwaitingRecovery, TaskApproval, UserResponse, ContextExhausted,
-- or Terminal (parent-only).
variant SubAgent : Conversation {
    parent: Conversation
    sub_agent_status: completed | failed

    grace_turn_granted: Boolean = false
    completion_result: String when sub_agent_status = completed
    failure_error: String when sub_agent_status = failed
    failure_error_class: ErrorClass? when sub_agent_status = failed

    is_terminal: sub_agent_status in { completed, failed }

    -- Sub-agent status is set exactly once, at terminal transition. There are
    -- no intermediate sub_agent_status values. Terminal states: completed,
    -- failed. (Not expressed as a v3 `transitions` block: grammar does not
    -- support transitions inside `variant` bodies.)
    --
    -- Entity-level invariant (grammar does not support `invariant` inside
    -- `variant` bodies either): sub-agents cannot spawn further sub-agents —
    -- for any SubAgent c, c.sub_agents.count = 0. Tracked as cross-cutting
    -- invariant NoRecursiveSubAgents below.
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    max_retry_attempts: Integer = 3
    retry_base_delay: Duration = 1.second
    context_warning_threshold: Decimal = 0.80
    context_continuation_threshold: Decimal = 0.90
    max_sub_agents_per_spawn: Integer = 10
}

------------------------------------------------------------
-- Rules: Core (shared by parent and sub-agent)
------------------------------------------------------------

-- ===========================================================
-- CORE 1. USER MESSAGE HANDLING (REQ-BED-002)
-- ===========================================================

rule UserSendsMessage {
    when: UserSendsMessage(conversation, text, images?)
    requires: conversation.core_status in { idle, error }
    requires: not conversation.is_terminal
    ensures: conversation.core_status = llm_requesting
    ensures: conversation.retry_attempt = 1
    ensures: LlmRequestDispatched(conversation)
}

rule RejectMessageWhileBusy {
    when: UserSendsMessage(conversation, text, images?)
    requires: conversation.is_busy
    ensures: MessageRejected(conversation, reason: agent_busy)
}

-- ===========================================================
-- CORE 2. LLM RESPONSE — TOOL DISPATCH (REQ-BED-003)
-- ===========================================================

rule LlmRespondsWithTools {
    when: LlmResponds(conversation, content, tool_calls, end_turn, usage)
    requires: conversation.core_status = llm_requesting
    requires: tool_calls.count > 0
    requires: not is_sole_intercepted_tool(tool_calls)
    requires: not conversation.context_at_threshold
    ensures: conversation.core_status = executing_tools
    ensures: conversation.tool_queue = tool_calls
    ensures: conversation.tool_results = {}
    ensures: conversation.accumulated_sub_agents = {}
    ensures: conversation.context_usage_ratio = usage_ratio(usage, conversation)
    ensures: ToolExecutionStarted(conversation, tool_calls.first)
}

-- Intercepted tool mixed with other tools -> error
rule InterceptedToolNotSole {
    when: LlmResponds(conversation, content, tool_calls, end_turn, usage)
    requires: conversation.core_status = llm_requesting
    requires: tool_calls.count > 1
    requires: tool_calls.any(t => is_intercepted_tool(t.name))
    ensures: conversation.core_status = error
    ensures: conversation.error_message =
        intercepted_tool_name(tool_calls) + " must be the only tool in response"
}

-- ===========================================================
-- CORE 3. TOOL EXECUTION (REQ-BED-004)
-- ===========================================================

rule ToolCompletesWithMoreRemaining {
    when: ToolCompletes(conversation, result)
    requires: conversation.core_status = executing_tools
    requires: conversation.tool_queue.count > 0
    ensures: conversation.tool_results.add(result)
    ensures: ToolExecutionStarted(conversation, conversation.tool_queue.first)
}

rule LastToolCompletesNoSubAgents {
    when: ToolCompletes(conversation, result)
    requires: conversation.core_status = executing_tools
    requires: conversation.tool_queue.count = 0
    requires: conversation.accumulated_sub_agents.count = 0
    ensures: conversation.tool_results.add(result)
    ensures: conversation.core_status = llm_requesting
    ensures: conversation.retry_attempt = 1
    ensures: ToolRoundCheckpointed(conversation)
    ensures: LlmRequestDispatched(conversation)
}

rule LastToolCompletesWithSubAgents {
    when: ToolCompletes(conversation, result)
    requires: conversation.core_status = executing_tools
    requires: conversation.tool_queue.count = 0
    requires: conversation.accumulated_sub_agents.count > 0
    ensures: conversation.tool_results.add(result)
    ensures: conversation.core_status = awaiting_sub_agents
    ensures: conversation.sub_agents_pending = conversation.accumulated_sub_agents
    ensures: conversation.sub_agents_completed = {}
    ensures: ToolRoundCheckpointed(conversation)
}

rule SpawnAgentsCompletesWithMoreTools {
    when: SpawnAgentsCompletes(conversation, result, spawned_agents)
    requires: conversation.core_status = executing_tools
    requires: conversation.tool_queue.count > 0
    ensures: conversation.tool_results.add(result)
    ensures:
        for agent in spawned_agents:
            conversation.accumulated_sub_agents.add(agent)
    ensures: ToolExecutionStarted(conversation, conversation.tool_queue.first)
}

rule SpawnAgentsCompletesAsLastTool {
    when: SpawnAgentsCompletes(conversation, result, spawned_agents)
    requires: conversation.core_status = executing_tools
    requires: conversation.tool_queue.count = 0
    ensures: conversation.tool_results.add(result)
    ensures:
        for agent in spawned_agents:
            conversation.accumulated_sub_agents.add(agent)
    ensures: conversation.core_status = awaiting_sub_agents
    ensures: conversation.sub_agents_pending = conversation.accumulated_sub_agents
    ensures: conversation.sub_agents_completed = {}
    ensures: ToolRoundCheckpointed(conversation)
}

-- ===========================================================
-- CORE 4. CANCELLATION (REQ-BED-005)
-- ===========================================================

rule CancelDuringToolExecution {
    when: UserCancels(conversation)
    requires: conversation.core_status = executing_tools
    ensures: conversation.core_status = cancelling_tool
    ensures: conversation.skipped_tools = conversation.tool_queue
    ensures: ToolAbortRequested(conversation)
}

rule ToolAbortConfirmed {
    when: ToolAborted(conversation)
    requires: conversation.core_status = cancelling_tool
    ensures: CancellationCheckpointed(conversation)
    ensures:
        if conversation.sub_agents_pending?.count = 0:
            conversation.core_status = idle
            AgentDone(conversation)
        else:
            conversation.core_status = cancelling_sub_agents
            SubAgentsCancelRequested(conversation)
}

rule ToolCompletesDuringCancellation {
    when: ToolCompletes(conversation, result)
    requires: conversation.core_status = cancelling_tool
    ensures: CancellationCheckpointed(conversation)
    ensures:
        if conversation.sub_agents_pending?.count = 0:
            conversation.core_status = idle
            AgentDone(conversation)
        else:
            conversation.core_status = cancelling_sub_agents
            SubAgentsCancelRequested(conversation)
}

rule CancelDuringSubAgentWait {
    when: UserCancels(conversation)
    requires: conversation.core_status = awaiting_sub_agents
    ensures: conversation.core_status = cancelling_sub_agents
    ensures: SubAgentsCancelRequested(conversation)
}

rule LastSubAgentDuringCancellation {
    when: SubAgentReportsResult(conversation, result)
    requires: conversation.core_status = cancelling_sub_agents
    requires: conversation.sub_agents_pending.count = 1
    ensures: conversation.sub_agents_completed.add(result)
    ensures: conversation.core_status = idle
    ensures: AgentDone(conversation)
}

rule SubAgentResultDuringCancellation {
    when: SubAgentReportsResult(conversation, result)
    requires: conversation.core_status = cancelling_sub_agents
    requires: conversation.sub_agents_pending.count > 1
    ensures: conversation.sub_agents_completed.add(result)
}

-- ===========================================================
-- CORE 5. ERROR RECOVERY (REQ-BED-006)
-- ===========================================================

rule RetryableLlmError {
    when: LlmErrors(conversation, message, error_class, attempt)
    requires: conversation.core_status = llm_requesting
    requires: error_class = retryable
    requires: attempt < config.max_retry_attempts
    ensures: conversation.retry_attempt = attempt + 1
    ensures: RetryScheduled(conversation, delay: config.retry_base_delay * attempt)
}

rule RetryTimeoutFires {
    when: RetryTimeoutExpires(conversation, attempt)
    requires: conversation.core_status = llm_requesting
    requires: conversation.retry_attempt = attempt
    ensures: LlmRequestDispatched(conversation)
}

-- ===========================================================
-- CORE 6. SUB-AGENT FAN-IN (REQ-BED-008)
-- ===========================================================

rule SubAgentReportsResultMorePending {
    when: SubAgentReportsResult(conversation, result)
    requires: conversation.core_status = awaiting_sub_agents
    requires: conversation.sub_agents_pending.count > 1
    ensures: conversation.sub_agents_completed.add(result)
}

rule LastSubAgentReportsResult {
    when: SubAgentReportsResult(conversation, result)
    requires: conversation.core_status = awaiting_sub_agents
    requires: conversation.sub_agents_pending.count = 1
    ensures: conversation.sub_agents_completed.add(result)
    ensures: conversation.core_status = llm_requesting
    ensures: conversation.retry_attempt = 1
    ensures: LlmRequestDispatched(conversation)
}

------------------------------------------------------------
-- Rules: Parent-only
------------------------------------------------------------

-- ===========================================================
-- PARENT 0. MESSAGE REJECTION IN PARENT-ONLY STATES
-- ===========================================================

rule RejectMessageDuringTaskApproval {
    when: UserSendsMessage(conversation, text, images?)
    requires: conversation.parent_status = awaiting_task_approval
    ensures: MessageRejected(conversation, reason: awaiting_approval)
}

rule RejectMessageDuringUserQuestion {
    when: UserSendsMessage(conversation, text, images?)
    requires: conversation.parent_status = awaiting_user_response
    ensures: MessageRejected(conversation, reason: awaiting_response)
}

rule RejectMessageContextExhausted {
    when: UserSendsMessage(conversation, text, images?)
    requires: conversation.parent_status = context_exhausted
    ensures: MessageRejected(conversation, reason: context_exhausted)
}

-- ===========================================================
-- PARENT 1. LLM RESPONSE — TEXT-ONLY AND INTERCEPTIONS
-- ===========================================================

rule ParentLlmRespondsTextOnly {
    when: LlmResponds(conversation, content, tool_calls, end_turn, usage)
    requires: conversation.core_status = llm_requesting
    requires: tool_calls.count = 0
    ensures: conversation.core_status = idle
    ensures: conversation.context_usage_ratio = usage_ratio(usage, conversation)
    ensures: AgentDone(conversation)
}

-- REQ-BED-028: propose_task interception (parent-only, managed mode only)
rule ProposeTaskIntercepted {
    when: LlmResponds(conversation, content, tool_calls, end_turn, usage)
    requires: conversation.core_status = llm_requesting
    requires: tool_calls.count = 1
    requires: tool_calls.first.name = "propose_task"
    requires: conversation.mode_kind = managed
    let proposal = parse_task_proposal(tool_calls.first)
    ensures: conversation.parent_status = awaiting_task_approval
    ensures: conversation.proposal = proposal
    ensures: TaskApprovalRequested(conversation, proposal)

    @guidance
        -- Mode guard: propose_task is rejected in Direct and Branch modes.
        -- The tool registry should prevent it, but the transition function
        -- guards defensively with mode_kind != managed -> Error.
}

rule AskUserQuestionIntercepted {
    when: LlmResponds(conversation, content, tool_calls, end_turn, usage)
    requires: conversation.core_status = llm_requesting
    requires: tool_calls.count = 1
    requires: tool_calls.first.name = "ask_user_question"
    let questions = parse_questions(tool_calls.first)
    ensures: conversation.parent_status = awaiting_user_response
    ensures: conversation.pending_questions = questions
}

-- REQ-BED-019: Context threshold reached (parent -> continuation)
rule ContextThresholdReachedParent {
    when: LlmResponds(conversation, content, tool_calls, end_turn, usage)
    requires: conversation.core_status = llm_requesting
    requires: conversation.context_at_threshold
    ensures: conversation.core_status = awaiting_continuation
    ensures: conversation.rejected_tool_calls = tool_calls
    ensures: conversation.retry_attempt = 1
    ensures: ContinuationRequested(conversation, tool_calls)
}

-- ===========================================================
-- PARENT 2. CANCELLATION (parent -> idle, not failed)
-- ===========================================================

rule ParentCancelDuringLlmRequest {
    when: UserCancels(conversation)
    requires: conversation.core_status = llm_requesting
    ensures: conversation.core_status = idle
    ensures: LlmAborted(conversation)
    ensures: AgentDone(conversation)
}

-- ===========================================================
-- PARENT 3. NON-RETRYABLE ERROR (parent -> error)
-- ===========================================================

rule ParentLlmErrorNonRecoverable {
    when: LlmErrors(conversation, message, error_class, attempt)
    requires: conversation.core_status = llm_requesting
    requires: error_class = non_retryable or attempt >= config.max_retry_attempts
    ensures: conversation.core_status = error
    ensures: conversation.error_message = message
    ensures: conversation.error_class = error_class
}

-- ===========================================================
-- PARENT 4. ACTIVE RECOVERY (REQ-BED-030)
-- ===========================================================

rule AuthErrorWithActiveRecovery {
    when: LlmErrors(conversation, message, error_class, attempt)
    requires: conversation.core_status = llm_requesting
    requires: error_class = non_retryable
    requires: error_kind = auth
    requires: CredentialHelperIsRunning
    ensures: conversation.parent_status = awaiting_recovery
    ensures: conversation.recovery_kind = credential
    ensures: conversation.recovery_message = message

    @guidance
        -- Checked before ParentLlmErrorNonRecoverable. The
        -- recovery_in_progress flag is enriched on the event by
        -- the executor (keeps transition function pure).
}

rule RecoverySucceeded {
    when: CredentialBecameAvailable
    requires: conversation.parent_status = awaiting_recovery
    ensures: conversation.core_status = llm_requesting
    ensures: conversation.retry_attempt = 1
    ensures: LlmRequestDispatched(conversation)
}

rule RecoveryFailed {
    when: CredentialHelperFailed(message)
    requires: conversation.parent_status = awaiting_recovery
    ensures: conversation.core_status = error
    ensures: conversation.error_message = message
    ensures: conversation.error_class = non_retryable
}

rule CancelDuringRecovery {
    when: UserCancels(conversation)
    requires: conversation.parent_status = awaiting_recovery
    ensures: conversation.core_status = idle
}

-- ===========================================================
-- PARENT 5. TASK APPROVAL (REQ-BED-028)
-- ===========================================================

rule UserApprovesTask {
    when: TaskApprovalDecided(conversation, decision)
    requires: conversation.parent_status = awaiting_task_approval
    requires: decision = approved
    ensures: conversation.mode = work
    ensures: conversation.core_status = llm_requesting
    ensures: conversation.retry_attempt = 1
    ensures: ModeTransitioned(conversation, from: explore, to: work)
    ensures: LlmRequestDispatched(conversation)
}

rule UserProvidesFeedback {
    when: TaskApprovalDecided(conversation, decision)
    requires: conversation.parent_status = awaiting_task_approval
    requires: decision = feedback_provided
    ensures: conversation.core_status = llm_requesting
    ensures: conversation.retry_attempt = 1
    ensures: LlmRequestDispatched(conversation)
}

rule UserRejectsTask {
    when: TaskApprovalDecided(conversation, decision)
    requires: conversation.parent_status = awaiting_task_approval
    requires: decision = rejected
    ensures: conversation.core_status = idle
    ensures: AgentDone(conversation)
}

rule CancelDuringTaskApproval {
    when: UserCancels(conversation)
    requires: conversation.parent_status = awaiting_task_approval
    ensures: conversation.core_status = idle
    ensures: AgentDone(conversation)
}

-- ===========================================================
-- PARENT 6. USER QUESTION RESPONSE
-- ===========================================================

rule UserAnswersQuestion {
    when: UserAnswersQuestion(conversation, answers, annotations?)
    requires: conversation.parent_status = awaiting_user_response
    ensures: conversation.core_status = llm_requesting
    ensures: conversation.retry_attempt = 1
    ensures: LlmRequestDispatched(conversation)
}

rule CancelDuringUserQuestion {
    when: UserCancels(conversation)
    requires: conversation.parent_status = awaiting_user_response
    ensures: conversation.core_status = llm_requesting
    ensures: conversation.retry_attempt = 1
    ensures: LlmRequestDispatched(conversation)
}

-- ===========================================================
-- PARENT 7. CONTEXT CONTINUATION (REQ-BED-019 through 024)
-- ===========================================================

rule UserTriggersContinuation {
    when: UserTriggersContinuation(conversation)
    requires: conversation.core_status = idle
    ensures: conversation.core_status = awaiting_continuation
    ensures: conversation.rejected_tool_calls = {}
    ensures: conversation.retry_attempt = 1
    ensures: ContinuationRequested(conversation, {})
}

rule ContinuationSummaryReceived {
    when: ContinuationSummaryReady(conversation, summary)
    requires: conversation.core_status = awaiting_continuation
    ensures: conversation.parent_status = context_exhausted
    ensures: conversation.continuation_summary = summary
}

rule ContinuationFailed {
    when: ContinuationRequestFailed(conversation, error)
    requires: conversation.core_status = awaiting_continuation
    ensures: conversation.parent_status = context_exhausted
    ensures: conversation.continuation_summary =
        "Continuation summary unavailable. Context was exhausted."
}

rule CancelDuringContinuation {
    when: UserCancels(conversation)
    requires: conversation.core_status = awaiting_continuation
    ensures: conversation.parent_status = context_exhausted
    ensures: conversation.continuation_summary =
        "Conversation ended by user during context continuation."
}

rule ContinuationRetryableError {
    when: LlmErrors(conversation, message, error_class, attempt)
    requires: conversation.core_status = awaiting_continuation
    requires: error_class = retryable
    requires: attempt < config.max_retry_attempts
    ensures: conversation.retry_attempt = attempt + 1
    ensures: RetryScheduled(conversation, delay: config.retry_base_delay * attempt)
}

rule ContinuationNonRecoverableError {
    when: LlmErrors(conversation, message, error_class, attempt)
    requires: conversation.core_status = awaiting_continuation
    requires: error_class = non_retryable or attempt >= config.max_retry_attempts
    ensures: conversation.parent_status = context_exhausted
    ensures: conversation.continuation_summary =
        "Continuation summary unavailable. Context was exhausted."
}

-- ===========================================================
-- PARENT 8. TERMINAL (REQ-BED-029)
-- ===========================================================

rule TaskResolved {
    when: TaskResolved(conversation, outcome)
    requires: conversation.core_status = idle
    requires: conversation.mode in { work, branch }
    ensures: conversation.parent_status = terminal
    ensures: ConversationBecameTerminal(conversation)
}

------------------------------------------------------------
-- Rules: Sub-agent-only
------------------------------------------------------------

-- ===========================================================
-- SUB-AGENT 1. IMPLICIT COMPLETION
-- ===========================================================

rule SubAgentImplicitCompletion {
    when: LlmResponds(conversation, content, tool_calls, end_turn, usage)
    requires: conversation.core_status = llm_requesting
    requires: tool_calls.count = 0
    requires: content = null
    ensures: conversation.sub_agent_status = completed
    ensures: conversation.completion_result = ""
    ensures: SubAgentCompleted(conversation)
}

-- Sub-agent text-only with content -> also implicit completion
rule SubAgentTextOnlyCompletion {
    when: LlmResponds(conversation, content, tool_calls, end_turn, usage)
    requires: conversation.core_status = llm_requesting
    requires: tool_calls.count = 0
    requires: content != null
    ensures: conversation.sub_agent_status = completed
    ensures: conversation.completion_result = extract_text(content)
    ensures: SubAgentCompleted(conversation)
}

-- ===========================================================
-- SUB-AGENT 2. SUBMIT RESULT / ERROR
-- ===========================================================

rule SubAgentSubmitsResult {
    when: LlmResponds(conversation, content, tool_calls, end_turn, usage)
    requires: conversation.core_status = llm_requesting
    requires: tool_calls.count = 1
    requires: tool_calls.first.name = "submit_result"
    ensures: conversation.sub_agent_status = completed
    ensures: conversation.completion_result = parse_result(tool_calls.first)
    ensures: SubAgentCompleted(conversation)
}

rule SubAgentSubmitsError {
    when: LlmResponds(conversation, content, tool_calls, end_turn, usage)
    requires: conversation.core_status = llm_requesting
    requires: tool_calls.count = 1
    requires: tool_calls.first.name = "submit_error"
    ensures: conversation.sub_agent_status = failed
    ensures: conversation.failure_error = parse_error(tool_calls.first)
    ensures: SubAgentCompleted(conversation)
}

-- ===========================================================
-- SUB-AGENT 3. CANCEL -> FAILED (not idle)
-- ===========================================================

rule SubAgentCancelled {
    when: UserCancels(conversation)
    requires: not conversation.is_terminal
    ensures: conversation.sub_agent_status = failed
    ensures: conversation.failure_error = UserCancels.reason or "Cancelled"
    ensures: SubAgentCompleted(conversation)
}

-- ===========================================================
-- SUB-AGENT 4. NON-RETRYABLE ERROR -> FAILED
-- ===========================================================

rule SubAgentLlmError {
    when: LlmErrors(conversation, message, error_class, attempt)
    requires: conversation.core_status = llm_requesting
    requires: error_class = non_retryable or attempt >= config.max_retry_attempts
    ensures: conversation.sub_agent_status = failed
    ensures: conversation.failure_error = message
    ensures: conversation.failure_error_class = error_class
    ensures: SubAgentCompleted(conversation)
}

-- ===========================================================
-- SUB-AGENT 5. CONTEXT EXHAUSTION -> FAILED
-- ===========================================================

rule SubAgentContextExhausted {
    when: LlmResponds(conversation, content, tool_calls, end_turn, usage)
    requires: conversation.core_status = llm_requesting
    requires: conversation.context_at_threshold
    ensures: conversation.sub_agent_status = failed
    ensures: conversation.failure_error = "Context exhausted before result submission"
    ensures: SubAgentCompleted(conversation)
}

-- ===========================================================
-- SUB-AGENT 6. GRACE TURN (REQ-BED-026)
-- ===========================================================

rule SubAgentTurnLimitGraceTurn {
    when: TurnLimitReached(conversation)
    requires: not conversation.grace_turn_granted
    ensures: conversation.grace_turn_granted = true
    ensures: SystemMessageInjected(conversation,
        "You have reached your turn limit. Please call submit_result now.")
    ensures: LlmRequestDispatched(conversation)

    @guidance
        -- Grace turn is an executor-level concern: the executor injects a
        -- system message and allows one more LLM request. Status stays at
        -- llm_requesting (no transition). If the model doesn't call
        -- submit_result, GraceTurnExhausted fires.
}

rule SubAgentTurnLimitHardStop {
    when: GraceTurnExhausted(conversation, partial_result)
    requires: conversation.grace_turn_granted = true
    ensures:
        if partial_result != null:
            conversation.sub_agent_status = completed
            conversation.completion_result = partial_result
            SubAgentCompleted(conversation) with outcome = success
        else:
            conversation.sub_agent_status = failed
            conversation.failure_error = "Turn limit exceeded, no output"
            SubAgentCompleted(conversation) with outcome = failure
}

------------------------------------------------------------
-- Rules: Lifecycle and cross-cutting
------------------------------------------------------------

-- Lifecycle announcement: fires when any conversation reaches terminal.
rule ConversationReachedTerminalState {
    when: conversation: Conversation.is_terminal becomes true
    ensures: ConversationBecameTerminal(conversation)

    @guidance
        -- Downstream specs (terminal, metrics) subscribe to this event.
        -- Consumers should check conversation.kind if they care only
        -- about parent conversations.
}

-- REQ-BED-017: Mode change injects synthetic message
rule ModeChangeNotification {
    when: ModeTransitioned(conversation, from, to)
    ensures: SyntheticMessageInjected(conversation, about: mode_changed)
}

-- REQ-BED-007: Persist state before effects (cross-cutting)
-- Every rule that changes status implicitly requires state persistence
-- before side effects execute.

-- REQ-BED-007: Server restart restores to idle
rule ServerRestart {
    when: ServerRestarted(conversation)
    requires: conversation.is_busy
    ensures: conversation.core_status = idle
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

-- Sub-agents cannot spawn further sub-agents (was a variant-level invariant,
-- moved here because Allium v3 grammar does not support invariants inside
-- `variant` bodies).
invariant NoRecursiveSubAgents {
    for c in SubAgent:
        c.sub_agents.count = 0
}

-- Sub-agent notifies parent exactly once
invariant SubAgentNotifiesParentOnce {
    for c in SubAgent:
        count(SubAgentCompleted(c)) <= 1
}

-- Grace turn resolves to terminal
invariant GraceTurnOutcome {
    for c in SubAgent:
        c.grace_turn_granted and c.is_terminal
            implies (c.sub_agent_status = completed or c.sub_agent_status = failed)
}

-- REQ-BED-001: Pure state transitions
-- Enforced by construction: transitions are pure functions.

-- REQ-BED-004: Tool round atomicity
-- tool_use count = tool_result count at checkpoint time.

-- REQ-BED-008: Sub-agent fan-in conservation
-- pending + completed = total spawned (constant).
-- Enforced by construction: each SubAgentReportsResult moves one.

invariant ThresholdOrdering {
    config.context_continuation_threshold > config.context_warning_threshold
}

invariant SpawnLimit {
    for c in Conversations:
        c.core_status = executing_tools
            implies c.accumulated_sub_agents.count <= config.max_sub_agents_per_spawn
}

------------------------------------------------------------
-- Actor Declarations
------------------------------------------------------------

actor User {
    identified_by: Parent
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface UserConversation {
    facing user: User

    context conversation: Parent

    exposes:
        conversation.core_status
        conversation.parent_status
        conversation.mode
        conversation.context_usage_ratio
        conversation.context_warning
        conversation.proposal when conversation.parent_status = awaiting_task_approval
        conversation.pending_questions when conversation.parent_status = awaiting_user_response
        conversation.error_message when conversation.core_status = error
        conversation.recovery_message when conversation.parent_status = awaiting_recovery
        conversation.recovery_kind when conversation.parent_status = awaiting_recovery
        conversation.continuation_summary when conversation.parent_status = context_exhausted

    provides:
        UserSendsMessage(conversation, text, images?)
            when conversation.core_status in { idle, error }
        UserCancels(conversation)
            when conversation.is_busy
                 or conversation.parent_status in {
                    awaiting_task_approval,
                    awaiting_user_response,
                    awaiting_recovery
                 }
        TaskApprovalDecided(conversation, decision)
            when conversation.parent_status = awaiting_task_approval
        UserAnswersQuestion(conversation, answers, annotations?)
            when conversation.parent_status = awaiting_user_response
        UserTriggersContinuation(conversation)
            when conversation.core_status = idle and conversation.context_warning

    @guarantee IdempotentMessages
        -- Duplicate message submissions (same message_id) are
        -- silently accepted without creating duplicate messages.

    @guarantee ImmediateCancel
        -- Cancellation is processed with higher priority than
        -- operation completion. Never queued behind current work.
}

-- No open questions remain.
