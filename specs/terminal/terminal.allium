-- allium: 3
-- terminal.allium
--
-- Phoenix Terminal: Behavioural Specification
--
-- Scope: PTY-backed browser terminal per conversation
-- Includes: Terminal session lifecycle, PTY spawn, WebSocket I/O relay,
--           resize handling, command tracker, terminal_last_command,
--           terminal_command_history, session teardown,
--           conversation-terminal cascade,
--           authentication identity precondition (session-scoped user)
-- Excludes:
--   - UI panel placement (deferred to implementation)
--   - Scrollback persistence (ephemeral; tmux integration deferred)
--   - macOS PTY kqueue considerations (Linux target for v1)
--   - Multiple terminals per conversation (exactly one)
--   - PTY privilege escalation (API runs as same Unix user as shell)
--   - WebSocket auth mechanism specifics (cookie vs header; see design.md)
--
-- Requirement traceability: REQ-TERM-001 through REQ-TERM-014, REQ-TERM-021 through REQ-TERM-023
-- Dependencies: specs/bedrock/bedrock.allium

use "../bedrock/bedrock.allium" as bedrock

------------------------------------------------------------
-- Actor Declarations
------------------------------------------------------------

-- A user is identified by a valid API session. The same session mechanism
-- used by all other API endpoints applies to the WebSocket upgrade request.
-- The auth mechanism (cookie, bearer header) is an implementation detail
-- specified in design.md. Allium governs the identity precondition: only
-- a session-authenticated user may open or close a terminal.
actor User {
    identified_by: ApiSession
}

-- An LLM agent running within a conversation may read terminal contents.
-- Agents do not open or close terminals.
actor LlmAgent {
    identified_by: bedrock/Conversation
}

------------------------------------------------------------
-- External Entities
------------------------------------------------------------

-- The kernel PTY subsystem: line discipline, SIGHUP chain, SIGWINCH delivery.
-- This spec does not govern kernel internals, only what the API triggers.
external entity KernelPty {
}

-- The browser terminal emulator. Sends/receives binary WebSocket frames.
-- FitAddon computes cols/rows from the DOM on connect and on resize.
external entity XtermJs {
    cols: Integer
    rows: Integer
}

-- The user's shell process. Holds the PTY slave fd as its controlling terminal.
-- Has no awareness of WebSocket, xterm.js, or the API server.
external entity ShellProcess {
    pid: Integer
}

-- The shell or prompt framework (e.g. powerlevel10k, Starship, manual
-- precmd/preexec hooks, fish 3.6+ built-in support) that emits OSC 133
-- and OSC 7 markers on the PTY byte stream. Phoenix models only the
-- contract at the byte-stream boundary; the provider's internals are
-- opaque. (REQ-TERM-015 through REQ-TERM-018)
external entity ShellIntegrationProvider {
}

------------------------------------------------------------
-- Value Types
------------------------------------------------------------

value TerminalDimensions {
    cols: Integer    -- must be > 0
    rows: Integer    -- must be > 0
}

-- WebSocket binary frame (type-prefixed).
-- 0x00 | <raw bytes>            PTY data (bidirectional)
-- 0x01 | u16be cols | u16be rows  Resize (client → server only)
value WsFrame {
    kind: data | resize
}

-- A single command executed via the shell, tracked via OSC 133 markers.
-- Populated at C, finalised at D. (REQ-TERM-016, REQ-TERM-021)
value CommandRecord {
    command_text: String       -- payload of OSC 133;C (may be empty)
    output:       String       -- text captured between C and D; ANSI stripped; may include disk path when truncated
    started_at:   Timestamp    -- when C was processed
    duration_ms:  Integer      -- milliseconds from C to D
    exit_code:    Integer?     -- from OSC 133;D payload; None when D omits code — do not substitute 0
}

------------------------------------------------------------
-- Enumerations
------------------------------------------------------------

-- Shell integration detection state for a terminal session.
-- Transitions are one-shot: unknown → detected OR unknown → absent.
-- See ShellIntegrationStatusMonotonic invariant.
enum ShellIntegrationStatus {
    unknown    -- initial, within detection window
    detected   -- OSC 133 marker observed within window
    absent     -- detection window elapsed without any marker
}

------------------------------------------------------------
-- Entities
------------------------------------------------------------

entity Terminal {
    -- The conversation this terminal is scoped to.
    conversation: bedrock/Conversation

    -- Lifecycle state.
    status: absent | active

    transitions status {
        absent -> active
        active -> absent
        -- "absent" is both the initial and terminal state.
        -- A new WebSocket connection on a conversation with status=absent
        -- opens a fresh terminal. Closing returns to absent.
    }

    -- Fields present only while active (REQ-TERM-001, REQ-TERM-010).
    master_fd:  OwnedFd            when status = active
    child_pid:  Pid                when status = active
    dimensions: TerminalDimensions when status = active

    -- Shell integration fields (REQ-TERM-015 through REQ-TERM-018).
    -- Initial value of shell_integration_status is `unknown`; it transitions
    -- monotonically via ShellIntegrationDetected or ShellIntegrationDetectionTimedOut.
    shell_integration_status: ShellIntegrationStatus when status = active

    -- Ring buffer of completed command records. Capacity 5; oldest evicted on overflow.
    -- Empty when shell_integration_status != detected. (REQ-TERM-021)
    command_records: RingBuffer(CommandRecord, capacity=5)
        when status = active and shell_integration_status = detected

    -- The currently executing command (if any). Set by CommandExecutionStarted,
    -- cleared by CommandExecutionFinished. At most one at a time
    -- (OneExecutingCommandAtATime).
    current_command: CommandRecord?
        when status = active and shell_integration_status = detected

    -- Output accumulation buffer: printable characters appended by CommandTracker
    -- between a C and D marker. Cleared on CommandExecutionStarted, finalised on
    -- CommandExecutionFinished. Lives inside CommandTracker; exposed here as a
    -- conceptual entity field for the ensures clauses in those rules.
    output_buffer: String
        when status = active and shell_integration_status = detected

    -- The most recently completed command. Set by CommandExecutionFinished,
    -- cleared by CommandExecutionStarted on the next OSC 133;C. Drives the
    -- transient ✓/✗ display in the HUD.
    last_completed_command: CommandRecord?
        when status = active and shell_integration_status = detected

    -- Working directory reported via OSC 7. None means "never reported";
    -- the HUD falls back to conversation.working_dir in that case.
    reported_cwd: Path? when status = active
}

------------------------------------------------------------
-- Config
------------------------------------------------------------

config {
    output_channel_bound: Integer = 4096
    -- Maximum bytes buffered in the master-fd→WebSocket channel before backpressure.
    -- Prevents fast producers (yes, large cat) from unboundedly queuing.

    shell_integration_detection_window: Duration = 5.s
    -- Bytes must contain at least one OSC 133 C marker within this window from
    -- terminal spawn or the session is locked at shell_integration_status = absent.
    -- (REQ-TERM-015)

    command_record_ring_capacity: Integer = 5
    -- Maximum CommandRecord entries retained per terminal session.
    -- When a 6th command completes, the oldest record is evicted. (REQ-TERM-021)

    command_output_truncation_threshold: Integer = 131072
    -- 128KB. Output exceeding this is written to disk; a truncated preview + path
    -- is stored in CommandRecord.output. Matches bash tool MAX_OUTPUT_LENGTH. (REQ-TERM-021)
}

------------------------------------------------------------
-- Rules
------------------------------------------------------------

-- REQ-TERM-001, REQ-TERM-002: Terminal opened, PTY spawned
rule TerminalOpened {
    when: UserOpensTerminal(conversation)

    requires: not conversation.is_terminal
    requires: Terminal(conversation).status = absent

    ensures: terminal: Terminal.status = active
    ensures: PtySpawned(terminal)

    @guidance
        -- Spawn sequence (run in spawn_blocking or before async handoff):
        --   1. openpty() → master_fd + slave_fd
        --   2. fork()
        --      [child]:
        --        setsid()                      new session, child is leader
        --        ioctl(slave_fd, TIOCSCTTY, 0) slave becomes controlling tty
        --        dup2(slave_fd, 0/1/2)         slave is stdin, stdout, stderr
        --        close(slave_fd)               fd already dup'd
        --        chdir(conversation.working_dir)  conversation working directory
        --        -- working_dir corresponds to REQ-BED-010; same field used by projects.allium
        --        execvp($SHELL, ["-i"])         with explicit env (REQ-TERM-002)
        --      [parent]:
        --        close(slave_fd)               parent must not hold slave open
        --        store master_fd in TerminalHandle
        --   3. Before entering normal I/O: wait for the first resize frame from
        --      xterm.js FitAddon (REQ-TERM-005). The client sends it immediately
        --      on connect; treat it as a required handshake, not optional input.
        --      Apply via ResizeApplied before the shell produces its first prompt.
        --   4. Spawn two async tasks:
        --        Task A: loop { read(master_fd) → WS frame + command_tracker.ingest(bytes) }
        --                EIO → clean shutdown
        --        Task B: loop { WS frame → write(master_fd) | ioctl(TIOCSWINSZ) }
        --   5. Both tasks hold Arc<TerminalHandle>. Either exiting shuts down the other.
}

-- REQ-TERM-002: Explicit environment construction
rule ShellEnvironmentConstructed {
    when: PtySpawned(terminal)

    ensures: ShellProcess.env = {
        TERM:      "xterm-256color",
        COLORTERM: "truecolor",
        HOME:      user_home_dir(),
        USER:      current_username(),
        SHELL:     user_shell(),
        PATH:      user_path(),
        LANG:      "en_US.UTF-8",
    }

    @guidance
        -- Do NOT inherit the API server's process environment.
        -- The server env may contain secrets (API keys, tokens).
        -- TERM=xterm-256color is the most critical variable:
        -- wrong or missing causes readline degradation, broken arrow keys,
        -- and misbehaviour in vim, htop, and similar programs.
}

-- REQ-TERM-003: Duplicate connection reclaims the existing session.
-- Task 24691: the prior 409-rejection behaviour stranded sessions when the
-- browser-side WebSocket died silently (tab crash, network drop, laptop
-- sleep); the shell was still healthy but no recovery was possible without a
-- server-side kill. Reclaim evicts the sitting relay without tearing down
-- the shell, then attaches the new WebSocket to the same handle.
rule DuplicateConnectionReclaimsSession {
    when: UserOpensTerminal(conversation)

    requires: Terminal(conversation).status = active

    ensures: Terminal(conversation).status = active
        -- Terminal stays active throughout reclaim — shell, master_fd,
        -- CommandTracker, and ring buffer are preserved.
    ensures: WebSocketAttached(conversation)
        -- The new WebSocket becomes the active relay target.

    @guidance
        -- Reclaim sequence (ws.rs handle_socket → acquire_handle → reclaim):
        --   1. Look up the existing Arc<TerminalHandle> in ActiveTerminals.
        --   2. Signal the sitting relay: stop_tx.send(StopReason::Detach).
        --   3. Await TerminalHandle.detached.notified() — the old relay
        --      fires this on clean exit. Bounded by a 5s timeout so a stuck
        --      relay cannot deadlock the reclaimer.
        --   4. Reset stop_tx to StopReason::Running before the new relay
        --      subscribes so it does not observe the stale Detach.
        --   5. Build a fresh PtyMasterIo via dup(master_fd) — each relay
        --      owns its own fd so drops don't affect the master.
        --   6. Start a new relay reusing the existing CommandTracker so
        --      mid-command output continues streaming.
        --
        -- Concurrent reclaim (two connections race for the same session):
        -- Notify's single-permit semantics allow exactly one waker to
        -- consume a notify; the bounded 5s timeout ensures the loser
        -- proceeds rather than deadlocking.
        --
        -- Out of scope: dead-peer detection. A separate follow-up task
        -- will add WS ping/pong so abandoned sessions (user never
        -- reconnects) are eventually reaped.
}

-- REQ-TERM-004, REQ-TERM-010: PTY output forwarded to WebSocket and command tracker
rule PtyOutputForwarded {
    when: BytesReadFromMaster(terminal, bytes)

    requires: terminal.status = active

    ensures: WebSocketBinaryFrameSent(terminal, prefix: 0x00, payload: bytes)
    ensures: terminal.command_tracker.ingest(bytes)
        -- Same bytes, same order, no gaps. Both ensures fire in the same handler.

    @guidance
        -- The CommandTracker is a state machine over OSC 133 boundaries. Dropped or
        -- reordered bytes can corrupt C/D pairing, producing garbled output records
        -- or missed commands. The two ensures (WS send and tracker ingest) must occur
        -- together with no interleaving path that skips either.
        --
        -- The internal master-fd→WebSocket channel is bounded to config.output_channel_bound
        -- bytes. A slow WebSocket consumer causes backpressure that pauses reads from
        -- master_fd, which is correct: the kernel buffers on the PTY side.
        -- Do NOT drop bytes to relieve backpressure; the tracker would miss boundaries.
}

-- REQ-TERM-005: Initial resize applied before first prompt
rule InitialResizeSent {
    -- Triggered by the first resize frame the client sends on connect.
    -- xterm.js FitAddon computes cols/rows from the DOM and sends this
    -- as its first WebSocket message before any user input.
    when: FirstResizeFrameReceived(terminal, dimensions)

    requires: terminal.status = active

    ensures: ResizeApplied(terminal, dimensions)

    @guidance
        -- The implementation holds off entering normal I/O loops until this
        -- frame arrives. The client is contractually required to send it first.
        -- "First" is defined as: no PTY output bytes have yet been forwarded
        -- to the WebSocket. If the client sends a data frame before a resize
        -- frame, treat the data frame normally and log a warning; the shell
        -- will have started at its PTY default size (80×24).
}

-- REQ-TERM-006: Resize applied to PTY
rule ResizeApplied {
    when: ResizeFrameReceived(terminal, dimensions)

    requires: terminal.status = active
    requires: dimensions.cols >= 2
    requires: dimensions.rows > 0

    ensures: terminal.dimensions = dimensions
    ensures: IoctlTIOCSWINSZ(terminal.master_fd, dimensions)
        -- Kernel delivers SIGWINCH to foreground process group automatically

    @guidance
        -- apply_resize() applies only the ioctl. The CommandTracker has no
        -- concept of screen dimensions; no tracker update is needed.
}

-- REQ-TERM-006: Invalid resize dimensions logged
rule ResizeFrameRejected {
    when: ResizeFrameReceived(terminal, dimensions)

    requires: terminal.status = active
    requires: dimensions.cols < 2 or dimensions.rows <= 0
        -- cols >= 2: cols=0 and cols=1 are both invalid for PTY operations.
        -- All construction sites use Dims::try_new which encodes this structurally.

    ensures: InvalidResizeDimensionsLogged(terminal, dimensions)
        -- No state change; dimensions remain as before.
        -- Log at tracing::warn level for debugging.
}

-- REQ-TERM-004: User input forwarded to PTY
rule UserInputForwarded {
    when: DataFrameReceived(terminal, bytes)

    requires: terminal.status = active

    ensures: BytesWrittenToMaster(terminal, bytes)
        -- Type byte (0x00) stripped before write.

    @guidance
        -- Echo, line discipline processing, and special character dispatch
        -- (Ctrl-C → SIGINT, Ctrl-Z → SIGTSTP, Ctrl-D → EOF) are all handled
        -- by the kernel line discipline. This rule writes raw bytes only.
}

-- REQ-TERM-007, REQ-TERM-009: Shell exits (EIO)
rule ShellExited {
    when: EioOnMasterRead(terminal)

    requires: terminal.status = active

    ensures: ChildReaped(terminal.child_pid)
        -- waitpid() called to prevent zombie processes
    ensures: WebSocketClosed(terminal)
    ensures: terminal.status = absent

    @guidance
        -- EIO is PTY EOF: the slave fd closed because the shell exited.
        -- This is NOT an error condition. Log at tracing::debug, not error.
        -- waitpid() belongs here (Task A) because Task A observes EIO first.
}

-- REQ-TERM-008: User closes terminal (WebSocket disconnect)
rule UserClosedTerminal {
    -- UserClosedTerminal is the event the surface provides (see UserTerminalAccess).
    -- It covers both deliberate close (UI button) and WebSocket disconnect
    -- (network drop, page refresh). From the system's perspective these are
    -- identical: the WebSocket is gone, teardown begins.
    when: UserClosedTerminal(terminal)

    requires: terminal.status = active

    ensures: MasterFdClosed(terminal)
        -- Closing master_fd triggers kernel SIGHUP to shell's process group.
        -- Shell receives SIGHUP and exits → slave fd closes → Task A reads EIO.
        -- Task A then calls waitpid() to reap the child (ShellExited rule).
    ensures: terminal.status = absent

    @guidance
        -- master_fd closure happens via Drop on TerminalHandle.
        -- Do NOT call waitpid() here; let the reader task (Task A) observe EIO
        -- and reap. Calling it in two places risks a race or double-reap.
}

-- REQ-TERM-022: Agent reads most recent command record (success)
rule AgentCallsTerminalLastCommand {
    when: AgentCallsTerminalLastCommand(conversation)

    requires: Terminal(conversation).status = active
    requires: terminal.shell_integration_status = detected
    requires: terminal.command_records not empty

    ensures: AgentReceivesCommandRecord(terminal.command_records.last())

    @guidance
        -- Returns the most recently completed CommandRecord from the ring buffer.
        -- The record includes command_text, output, exit_code, started_at,
        -- and duration_ms. If output was truncated, the output field contains
        -- a preview + disk path (see REQ-TERM-021 / CommandExecutionFinished).
}

-- REQ-TERM-022: Shell integration absent — terminal_last_command returns error
rule AgentCallsTerminalLastCommandAbsent {
    when: AgentCallsTerminalLastCommand(conversation)

    requires: Terminal(conversation).status = active
    requires: terminal.shell_integration_status != detected

    ensures: AgentReceivesError("shell integration is not active for this terminal — install the shell integration snippet to enable command tracking")
}

-- REQ-TERM-022: Ring buffer empty — terminal_last_command returns error
rule AgentCallsTerminalLastCommandEmpty {
    when: AgentCallsTerminalLastCommand(conversation)

    requires: Terminal(conversation).status = active
    requires: terminal.shell_integration_status = detected
    requires: terminal.command_records is empty

    ensures: AgentReceivesError("no commands have completed in this terminal session yet")
}

-- REQ-TERM-023: Agent reads command history (success)
rule AgentCallsTerminalCommandHistory {
    when: AgentCallsTerminalCommandHistory(conversation, count)

    requires: Terminal(conversation).status = active
    requires: terminal.shell_integration_status = detected
    requires: terminal.command_records not empty
    requires: count >= 1 and count <= 5

    ensures: AgentReceivesCommandRecords(terminal.command_records.last(count))
        -- Returns up to `count` records newest-first. Default count = 3 when omitted.

    @guidance
        -- count defaults to 3 when not supplied by the caller; max is 5 (ring capacity).
        -- Records are returned newest-first (most recent command at index 0).
        -- If fewer than count records exist, return all available records.
}

-- REQ-TERM-023: Shell integration absent — terminal_command_history returns error
rule AgentCallsTerminalCommandHistoryAbsent {
    when: AgentCallsTerminalCommandHistory(conversation, count)

    requires: Terminal(conversation).status = active
    requires: terminal.shell_integration_status != detected

    ensures: AgentReceivesError("shell integration is not active for this terminal — install the shell integration snippet to enable command tracking")
}

-- REQ-TERM-023: Ring buffer empty — terminal_command_history returns error
rule AgentCallsTerminalCommandHistoryEmpty {
    when: AgentCallsTerminalCommandHistory(conversation, count)

    requires: Terminal(conversation).status = active
    requires: terminal.shell_integration_status = detected
    requires: terminal.command_records is empty

    ensures: AgentReceivesError("no commands have completed in this terminal session yet")
}

-- REQ-TERM-012: Terminal torn down when conversation ends
rule TerminalAbandonedWithConversation {
    -- Subscribes to bedrock's ConversationBecameTerminal lifecycle announcement,
    -- emitted whenever a conversation's is_terminal derived value becomes true
    -- (status enters { context_exhausted, terminal, completed, failed }).
    -- Using the named event rather than a cross-spec state-watch keeps the
    -- cross-spec contract explicit and navigable. See tasks/08658 for rationale.
    when: bedrock/ConversationBecameTerminal(conversation)

    requires: Terminal(conversation).status = active

    ensures: MasterFdClosed(terminal)
        -- SIGHUP chain fires; shell exits; Task A observes EIO; waitpid() called.
    ensures: terminal.status = absent

    @guidance
        -- Terminal sessions must not outlive their conversation.
        -- Wire to bedrock's ConversationBecameTerminal event in the runtime executor.
        -- Note: this fires for sub-agent conversations too (completed/failed).
        -- Sub-agent conversations do not have terminals (OneTerminalPerConversation
        -- only applies to user-facing conversations), so the requires guard
        -- Terminal(conversation).status = active naturally excludes them.
}

-- REQ-TERM-015 (revised): OSC 133 detection on first C marker
rule ShellIntegrationDetected {
    when: Osc133MarkerReceived(terminal, 'C', _payload)

    requires: terminal.status = active
    requires: terminal.shell_integration_status = unknown

    ensures: terminal.shell_integration_status = detected

    @guidance
        -- Detection fires specifically on C, not on any OSC 133 marker.
        -- Rationale: prompt-boundary markers A and B (as emitted by
        -- powerlevel10k's built-in shell integration) give us no actionable
        -- data for the rich HUD. A "detected" status that cannot track
        -- commands would mislead users. Conservative detection keeps the
        -- HUD honest.
        --
        -- The C marker that triggers detection is also processed by
        -- CommandExecutionStarted in the same handler pass.
}

-- REQ-TERM-015: detection window elapses without any marker
rule ShellIntegrationDetectionTimedOut {
    when: TerminalElapsedSinceSpawn(terminal) = config.shell_integration_detection_window

    requires: terminal.status = active
    requires: terminal.shell_integration_status = unknown

    ensures: terminal.shell_integration_status = absent

    @guidance
        -- Implementation: a single setTimeout (or tokio sleep, depending on
        -- whether the detection state lives client-side or server-side) is
        -- started when the xterm mounts and cancelled if
        -- shell_integration_status transitions to `detected` first.
        -- v1 puts this state in the frontend since xterm.js handles OSC parsing.
}

-- REQ-TERM-016 (revised): OSC 133;C → start a command execution
rule CommandExecutionStarted {
    when: Osc133MarkerReceived(terminal, 'C', command_text)

    requires: terminal.status = active
    requires: terminal.shell_integration_status = detected

    ensures: terminal.current_command = CommandRecord(
        command_text: command_text,
        output:       "",
        started_at:   now(),
        duration_ms:  0,
        exit_code:    None,
    )
    ensures: terminal.output_buffer = ""
    ensures: terminal.last_completed_command = None

    @guidance
        -- OSC 133;C payload is the user's typed command (text between B and C).
        -- Shells that do not populate this payload emit an empty C; treat it as
        -- an empty string, not null. If current_command was already non-None
        -- when this fires (e.g. a subshell's C arrives while the outer command
        -- still runs), overwrite — OneExecutingCommandAtATime holds at the
        -- outer-terminal level only.
        --
        -- Clearing last_completed_command here (moved from the old
        -- NewPromptClearsLastCompletedCommand rule) gives the ✓/✗ indicator
        -- a useful visible lifetime: it persists from D until the user types
        -- their next command and hits Enter. Clearing on A instead produced
        -- ~50ms of visibility in shells that emit A back-to-back with D.
}

-- REQ-TERM-016, REQ-TERM-021: OSC 133;D → finish the current command
rule CommandExecutionFinished {
    when: Osc133MarkerReceived(terminal, 'D', exit_code_opt)

    requires: terminal.status = active
    requires: terminal.shell_integration_status = detected
    requires: terminal.current_command != None

    ensures: terminal.last_completed_command = CommandRecord(
        command_text: terminal.current_command.command_text,
        output:       finalize(terminal.output_buffer),
        started_at:   terminal.current_command.started_at,
        duration_ms:  elapsed_ms(terminal.current_command.started_at, now()),
        exit_code:    exit_code_opt,
    )
    ensures: terminal.command_records.push(terminal.last_completed_command)
    ensures: terminal.current_command = None

    @guidance
        -- OSC 133;D may be emitted with or without an exit code:
        --   D       → finished, exit code unknown (exit_code_opt = None)
        --   D;0     → finished, success
        --   D;N     → finished, failure with specific code N
        -- All three are valid. Store None when absent; never fabricate 0.
        --
        -- finalize(output_buffer): if len > 128KB, write full bytes to
        -- ~/.phoenix-ide/terminal-output/<session-id>/<seq>.txt and store a
        -- truncated preview with the path appended. This matches the bash tool's
        -- MAX_OUTPUT_LENGTH constant and truncate_output format.
        --
        -- command_records.push() evicts the oldest record if capacity (5) is
        -- exceeded before inserting the new one.
}

-- REQ-TERM-016: OSC 133;D with no current_command → no-op
rule CommandExecutionFinishedWithNoCurrent {
    when: Osc133MarkerReceived(terminal, 'D', _exit_code_opt)

    requires: terminal.status = active
    requires: terminal.shell_integration_status = detected
    requires: terminal.current_command = None

    ensures: DebugLogged(terminal, "OSC 133;D received with no current_command; ignoring")

    @guidance
        -- Shells sometimes emit D on empty prompts or after signals (Ctrl-C on
        -- a blank line). This is not an error. Logging at debug only avoids
        -- noise in production but leaves a trail for diagnosis.
}

-- REQ-TERM-016: OSC 133;A and ;B are accepted as no-ops (forward compat)
rule PromptBoundaryMarkerAccepted {
    when: Osc133MarkerReceived(terminal, kind, _payload)

    requires: terminal.status = active
    requires: terminal.shell_integration_status = detected
    requires: kind in ['A', 'B']

    ensures: nothing
        -- Intentional no-op. A and B are preserved in the surface for
        -- forward compatibility but do not trigger state changes under
        -- the revised model where last_completed_command clears on C.

    @guidance
        -- Historical: a previous version of this rule cleared
        -- last_completed_command on A. That produced ~50ms of visible
        -- lifetime for the ✓/✗ indicator in shells that emit A immediately
        -- after D. Clearing on C instead gives the user the entire
        -- "reading the result → typing the next command" window.
}

-- REQ-TERM-018: OSC 7 → update reported_cwd
rule CwdReportedFromOsc7 {
    when: Osc7CwdReceived(terminal, path)

    requires: terminal.status = active

    ensures: terminal.reported_cwd = path

    @guidance
        -- OSC 7 payload format: file://hostname/absolute/path
        -- Parse: strip "file://", strip the optional host up to the first "/",
        -- percent-decode the path component, accept as reported_cwd on success.
        -- Log at debug and leave unchanged on parse failure. The rule fires
        -- regardless of shell_integration_status because OSC 7 is independent
        -- from OSC 133 (a shell might emit one without the other).
}

------------------------------------------------------------
-- Invariants
------------------------------------------------------------

-- REQ-TERM-003
invariant OneTerminalPerConversation {
    for c in Conversations:
        count(Terminal where conversation = c and status = active) <= 1
}

-- REQ-TERM-010
invariant CommandTrackerFedEveryByte {
    -- Every byte delivered to the WebSocket client has also been ingested by the
    -- CommandTracker in the same order, with no gaps.
    -- Structural guarantee: PtyOutputForwarded has both the WS send and
    -- command_tracker.ingest() in its ensures block, with no conditional path
    -- that performs one without the other.
}

-- REQ-TERM-021
invariant CommandRecordRingBufferBound {
    for t in Terminals where t.status = active and t.shell_integration_status = detected:
        count(t.command_records) <= 5
    -- Maintained by CommandExecutionFinished calling pop_front before push
    -- when the buffer is at capacity.
}

-- REQ-TERM-015
invariant ShellIntegrationStatusMonotonic {
    -- Detection is one-shot per terminal session. Legal transitions for
    -- shell_integration_status while terminal.status = active:
    --
    --   unknown -> detected   (via ShellIntegrationDetected)
    --   unknown -> absent     (via ShellIntegrationDetectionTimedOut)
    --
    -- No other transitions. In particular, detected -> absent is NOT allowed
    -- even if the shell stops emitting markers. The HUD simply stops updating
    -- in that case. This keeps runtime state predictable and matches the
    -- product decision to "lock at 5s" to avoid mid-session HUD mode flips.
}

-- REQ-TERM-016
invariant OneExecutingCommandAtATime {
    for t in Terminals where t.status = active and t.shell_integration_status = detected:
        t.current_command != None implies (
            "exactly one command in executing state on this terminal"
        )
    -- Nested subshell OSC 133 interleaving is out of scope for v1.
    -- If a nested shell emits its own C while the outer command is still
    -- executing, CommandExecutionStarted overwrites current_command (the
    -- outer's lifecycle tracking is lost for that command).
}

-- REQ-TERM-016
invariant CommandLifecycleFieldsCoherent {
    for t in Terminals where t.shell_integration_status = detected:
        t.current_command != None implies (
            t.current_command.duration_ms = 0 and
            t.current_command.exit_code = None
        )
        t.last_completed_command != None implies (
            t.last_completed_command.duration_ms >= 0
        )
    -- An in-progress command has duration_ms=0 and no exit_code.
    -- A completed command has duration_ms >= 0; sub-millisecond commands produce
    -- duration_ms=0 due to as_millis() truncation. Presence in the ring buffer
    -- is the completeness sentinel, not a positive duration. exit_code may still
    -- be None if OSC 133;D omitted the code.
}

------------------------------------------------------------
-- Surfaces
------------------------------------------------------------

surface UserTerminalAccess {
    facing user: User
        -- User identity requires a valid ApiSession (REQ-TERM-013).
        -- The WebSocket upgrade request must carry the same session credentials
        -- as all other API endpoints. Unauthenticated upgrades are rejected
        -- with HTTP 401 before any PTY is created.

    context terminal: Terminal
    context conversation: bedrock/Conversation

    exposes:
        terminal.status

    provides:
        UserOpensTerminal(conversation)
            when Terminal(conversation).status = absent
            and not conversation.is_terminal

        UserClosedTerminal(terminal)
            when terminal.status = active

    @guarantee AuthenticatedSession
        -- Every operation on this surface requires a valid API session.
        -- The session is validated on the HTTP upgrade handshake, before
        -- the WebSocket is accepted and before any PTY is created.
        -- Mechanism: see design.md § WebSocket Authentication.

surface AgentTerminalAccess {
    facing agent: LlmAgent

    context conversation: bedrock/Conversation
    context terminal: Terminal

    exposes:
        terminal.status
        terminal.shell_integration_status
        terminal.command_records

    provides:
        AgentCallsTerminalLastCommand(conversation)
            -- Returns the most recent CommandRecord, or an error if shell
            -- integration is absent or no commands have completed yet.
            -- (REQ-TERM-022)

        AgentCallsTerminalCommandHistory(conversation, count)
            -- Returns up to `count` recent CommandRecords newest-first.
            -- count defaults to 3, max 5. Same error conditions as above.
            -- (REQ-TERM-023)
}

-- REQ-TERM-015, REQ-TERM-016, REQ-TERM-018: OSC 133 + OSC 7 contract
surface ShellIntegrationProtocol {
    facing provider: ShellIntegrationProvider
        -- The shell (or prompt framework) running inside the PTY.
        -- Phoenix treats the provider as opaque — only the markers emitted
        -- on the byte stream are part of the contract.

    context terminal: Terminal

    exposes:
        terminal.shell_integration_status
        terminal.current_command
        terminal.last_completed_command
        terminal.reported_cwd

    expects:
        Osc133MarkerReceived(terminal, 'A')
            -- FTCS_PROMPT_START — shell is about to render a new prompt.
            -- Clears last_completed_command.

        Osc133MarkerReceived(terminal, 'B')
            -- FTCS_COMMAND_START — prompt rendered, user input begins.
            -- Accepted for forward compatibility; no lifecycle rule uses it.

        Osc133MarkerReceived(terminal, 'C', command_text)
            -- FTCS_COMMAND_EXECUTED — user pressed Enter; command begins.
            -- Payload is the typed command text (may be empty string).

        Osc133MarkerReceived(terminal, 'D', exit_code?)
            -- FTCS_COMMAND_FINISHED — command completed.
            -- Optional payload is the exit code. None means "finished,
            -- exit code unknown"; do not substitute 0.

        Osc7CwdReceived(terminal, path)
            -- Current working directory report.
            -- Payload format: file://hostname/absolute/path (percent-encoded).

    @guarantee DetectionMonotonic
        -- Per the ShellIntegrationStatusMonotonic invariant: once detection
        -- settles to `detected` or `absent`, the provider cannot un-settle it
        -- for the lifetime of the terminal session. If the shell stops
        -- emitting markers mid-session, the HUD stops updating but status
        -- remains `detected`.

    @guarantee NoBackchannel
        -- Phoenix never writes OSC 133 or OSC 7 sequences back to the
        -- provider. The protocol is one-way: provider → Phoenix only.
        -- v1 does not implement automatic injection of the hooks (see
        -- ShellIntegrationAutoInjection in the Deferred section).
}

------------------------------------------------------------
-- Deferred
------------------------------------------------------------

deferred TmuxIntegration.named_sessions
    -- Persistent named sessions; reconnect to existing session on WS open.
    -- Future path for users who want scrollback or session persistence.
    -- KISS: named sessions only. See KT doc for context.

deferred ShellIntegrationAbsentFallback
    -- If evidence shows users need read-screen capability when shell integration
    -- is absent, a minimal grid scraper (vt100/alacritty_terminal) could be
    -- added as a fallback. Explicitly out of scope for this version: the
    -- command-record model (REQ-TERM-021 through REQ-TERM-023) requires
    -- shell integration; absent integration returns an error, not degraded output.
    -- Revisit if user feedback indicates the error is blocking enough workflows
    -- to justify the complexity of maintaining a grid scraper in parallel.

deferred ShellIntegrationAutoInjection
    -- Phoenix could inject OSC 133 precmd/preexec hooks into the user's shell
    -- by manipulating ZDOTDIR, --rcfile, or $BASH_ENV at spawn time. This
    -- would make shell integration work without any user action.
    --
    -- Deferred because:
    --   1. Conflicts with user's own rc file customisations are easy to
    --      introduce and hard to debug.
    --   2. Each shell needs its own injection approach.
    --   3. The opt-in snippet (REQ-TERM-017) is simpler and gives users
    --      control over what runs in their shell.
    --
    -- v1 ships detection + snippet-based opt-in (REQ-TERM-015 through -018).
    -- Revisit auto-injection if evidence shows users want the zero-config
    -- experience enough to accept the risk.

deferred macOsKqueueSupport
    -- PTY master fds have historically had kqueue quirks on macOS.
    -- Linux is the v1 target platform. Test on macOS before enabling.

------------------------------------------------------------
-- Open questions
------------------------------------------------------------

-- No open questions remain.
-- All decisions resolved during elicitation (see conversation dated April 2026):
--   - Same Unix user: yes, no setuid needed
--   - Max terminals per conversation: exactly 1 (409 on duplicate)
--   - UI placement: deferred to implementation
--   - Agent tool model: command-record model (REQ-TERM-021 through REQ-TERM-023),
--     replacing the grid-scrape v1 approach. Decisions resolved April 2026:
--       * read_terminal removed; absent shell integration → error (no fallback)
--       * Ring buffer capacity: 5
--       * Truncation threshold: 128KB (matching bash tool MAX_OUTPUT_LENGTH)
--       * Truncated output written to disk at
--         ~/.phoenix-ide/terminal-output/<session-id>/<seq>.txt
--       * Parser: vte crate directly (not alacritty_terminal); implements Perform
--       * No grid, no cursor tracking, no resize tracking in CommandTracker
--       * OSC 133 A/B remain no-ops
--   - WebSocket auth: same session as rest of API (mechanism in design.md)
--   - Output persistence: ephemeral; tmux integration deferred
--   - Cross-spec lifecycle trigger: bedrock/ConversationBecameTerminal (named
--     chained event) preferred over cross-spec state-watch on is_terminal.
--     Rationale and design discussion: tasks/08658.
--
-- Import path note: uses "../bedrock/bedrock.allium" (relative to terminal.allium).
-- projects.allium uses "./bedrock.allium" (same directory). Both are correct
-- relative paths; the terminal spec lives one level deeper than bedrock.
